{
  "id": "everyday",
  "title": "Everyday Objects",
  "entries": [
    {
      "id": "ev-libro",
      "word": "libro",
      "partOfSpeech": "noun",
      "translations": [
        "book"
      ],
      "relatedTagalog": "libro",
      "examples": [
        {
          "kp": "Mamasa ku ning libro king eskwela.",
          "en": "I read a book at school."
        },
        {
          "kp": "Ibie ke ing libro kaniya.",
          "en": "I will give the book to him/her."
        }
      ],
      "notes": "Spanish loanword (libro) used in Kapampangan and Tagalog alike. Refers to any bound book. Confidence: very high; widely attested."
    },
    {
      "id": "ev-tubig",
      "word": "tubig",
      "partOfSpeech": "noun",
      "translations": [
        "water"
      ],
      "relatedTagalog": "tubig",
      "examples": [
        {
          "kp": "Bisa ku ing tubig.",
          "en": "I want water."
        },
        {
          "kp": "Atin tubig king baldi.",
          "en": "There is water in the pail."
        }
      ],
      "notes": "Native Austronesian root shared across many Philippine languages. Refers to water in any context — drinking, rain, rivers. Confidence: very high."
    },
    {
      "id": "ev-susi",
      "word": "susi",
      "partOfSpeech": "noun",
      "translations": [
        "key"
      ],
      "relatedTagalog": "susi",
      "examples": [
        {
          "kp": "Ibie ke ing susi kang Carmen.",
          "en": "I will give the key to Carmen."
        },
        {
          "kp": "Atyu ya ing susi king lamesa.",
          "en": "The key is on the table."
        }
      ],
      "notes": "Shared with Tagalog. Refers to a physical key (door, lock, ignition). Confidence: very high; attested in existing pack sentences."
    },
    {
      "id": "ev-kotse",
      "word": "kotse",
      "partOfSpeech": "noun",
      "translations": [
        "car",
        "vehicle"
      ],
      "relatedTagalog": "kotse",
      "examples": [
        {
          "kp": "Atyu ya ing kotse king arap ning bale.",
          "en": "The car is in front of the house."
        },
        {
          "kp": "Maragul ya ing kotse na.",
          "en": "His car is big."
        }
      ],
      "notes": "From Spanish 'coche' via Tagalog. Refers to an automobile. Confidence: very high; attested in particles pack example sentences."
    },
    {
      "id": "ev-tao",
      "word": "tao",
      "partOfSpeech": "noun",
      "translations": [
        "person",
        "people",
        "human being"
      ],
      "relatedTagalog": "tao",
      "examples": [
        {
          "kp": "Dakal a tao king plasa.",
          "en": "There are many people at the plaza."
        },
        {
          "kp": "Atin lang tao king bale.",
          "en": "There are people at home."
        }
      ],
      "notes": "Shared Austronesian root across Philippine languages. Can be singular ('a person') or collective ('people'). Spelling variant 'tau' is also attested. Confidence: very high."
    },
    {
      "id": "ev-piso",
      "word": "piso",
      "partOfSpeech": "noun",
      "translations": [
        "peso",
        "one peso",
        "Philippine currency unit"
      ],
      "relatedTagalog": "piso",
      "examples": [
        {
          "kp": "Metung a piso ya ing sukli ku.",
          "en": "My change is one peso."
        },
        {
          "kp": "Atin ku ning piso king bulsa ku.",
          "en": "I have a peso in my pocket."
        }
      ],
      "notes": "From Spanish 'peso'. The base unit of Philippine currency. Also used informally to mean any single monetary unit. Confidence: very high."
    },
    {
      "id": "ev-larawan",
      "word": "larawan",
      "partOfSpeech": "noun",
      "translations": [
        "picture",
        "photo",
        "image",
        "portrait"
      ],
      "relatedTagalog": "larawan",
      "examples": [
        {
          "kp": "Malagu ya ing larawan mu.",
          "en": "Your picture is beautiful."
        },
        {
          "kp": "Atin larawan da king sala.",
          "en": "They have pictures in the living room."
        }
      ],
      "notes": "Shared with Tagalog. Covers photographs, paintings, drawings, and any visual image. Confidence: very high."
    },
    {
      "id": "ev-liham",
      "word": "liham",
      "partOfSpeech": "noun",
      "translations": [
