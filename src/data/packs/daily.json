      "word": "mapalad",
      "partOfSpeech": "adjective",
      "translations": [
        "lucky",
        "fortunate",
        "blessed"
      ],
      "relatedTagalog": "mapalad",
      "examples": [
        {
          "kp": "Mapalad ya ing anak ku.",
          "en": "My child is fortunate."
        },
        {
