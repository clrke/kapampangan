{
  "id": "colors",
  "title": "Colors & Describing",
  "entries": [
    {
      "id": "col-malutu",
      "word": "Malutu",
      "partOfSpeech": "adjective",
      "translations": ["red"],
      "relatedTagalog": "pula",
      "examples": [
        {"kp": "Malutu ya ing bulaklak.", "en": "The flower is red."},
        {"kp": "Malutu ing damit na.", "en": "Her dress is red."}
      ],
      "notes": "Formed from ma- + lutu. The root lutu refers to the color red, historically achieved through bangcuro tree bark dye. Distinct from lutu meaning 'cooked'."
    },
    {
      "id": "col-maputi",
      "word": "Maputi",
      "partOfSpeech": "adjective",
      "translations": ["white"],
      "relatedTagalog": "puti",
      "examples": [
        {"kp": "Maputi ya ing manuk.", "en": "The chicken is white."},
        {"kp": "Maputi ing t-shirt ku.", "en": "My t-shirt is white."}
      ],
      "notes": "Formed from ma- + puti. Well attested across Wiktionary and multiple Kapampangan vocabulary sources."
    },
    {
      "id": "col-matuling",
      "word": "Matuling",
      "partOfSpeech": "adjective",
      "translations": ["black"],
      "relatedTagalog": "itim",
      "examples": [
        {"kp": "Matuling ya ing asu.", "en": "The dog is black."},
        {"kp": "Matuling ing buhuk na.", "en": "Her hair is black."}
      ],
      "notes": "From tuling (blackness). Also functions as a noun meaning 'the color black'. Attested in Wiktionary and the Kapampangan Listorian blog sourcing Bergaño's vocabulary."
    },
    {
      "id": "col-mairó",
      "word": "Mairó",
      "partOfSpeech": "adjective",
      "translations": ["blue"],
      "relatedTagalog": "asul",
      "examples": [
        {"kp": "Mairó ya ing langit.", "en": "The sky is blue."},
        {"kp": "Mairó ing damit na.", "en": "His clothes are blue."}
      ],
      "notes": "From iró/irao, the Kapampangan root for blue. Related to tayum, the blue dye plant. Attested in Bigwas.com and Kapampangan Listorian. 'Asul' (loanword) also used in modern speech."
    },
    {
      "id": "col-mayaluntian",
      "word": "Mayaluntian",
      "partOfSpeech": "adjective",
      "translations": ["green"],
      "relatedTagalog": "berde",
      "examples": [
        {"kp": "Mayaluntian ya ing pananim.", "en": "The plant is green."},
        {"kp": "Mayaluntian ing burak na.", "en": "Its leaves are green."}
      ],
      "notes": "From aluntian/aluntiang, meaning green. Attested in Bigwas.com color list and Kapampangan Listorian (Bergaño's vocabulary). The adjective form uses the ma- prefix."
    },
    {
      "id": "col-mapapas",
      "word": "Mapapas",
      "partOfSpeech": "adjective",
      "translations": ["yellow"],
      "relatedTagalog": "dilaw",
      "examples": [
        {"kp": "Mapapas ya ing saging.", "en": "The banana is yellow."},
        {"kp": "Mapapas ing bulaklak dita.", "en": "That flower is yellow."}
      ],
      "notes": "From papas (the color yellow). Attested in Bigwas.com and Kapampangan Listorian sourcing Bergaño. Historically the yellow color was obtained from the ange root. Alternative term: mariló (from diló)."
    },
    {
      "id": "col-maragul",
      "word": "Maragul",
      "partOfSpeech": "adjective",
      "translations": ["big", "large"],
      "relatedTagalog": "malaki",
      "examples": [
        {"kp": "Maragul ya ing bale da.", "en": "Their house is big."},
        {"kp": "Maragul ing paru-paro.", "en": "The butterfly is large."}
      ],
      "notes": "From ma- + dagul. Plural: mangaragul. Superlative: pekamaragul. Confirmed in Wiktionary and multiple Kapampangan vocabulary lists."
    },
    {
      "id": "col-malati",
      "word": "Malati",
      "partOfSpeech": "adjective",
      "translations": ["small", "little"],
      "relatedTagalog": "maliit",
      "examples": [
        {"kp": "Malati ya ing pusa.", "en": "The cat is small."},
        {"kp": "Malati ing kwarto ku.", "en": "My room is small."}
      ],
      "notes": "From ma- + lati. Plural: mangalati. Confirmed in Wiktionary."
    },
    {
      "id": "col-mapali",
      "word": "Mapali",
      "partOfSpeech": "adjective",
      "translations": ["hot"],
      "relatedTagalog": "mainit",
      "examples": [
        {"kp": "Mapali ya ing danum.", "en": "The water is hot."},
        {"kp": "Mapali ing panahon ngeni.", "en": "The weather is hot today."}
      ],
      "notes": "From ma- + pali. Confirmed in Wiktionary and multiple Kapampangan vocabulary sources. Note: one source spelled it 'mapoli' but 'mapali' is the standard attested form."
    },
    {
      "id": "col-marimla",
      "word": "Marimla",
      "partOfSpeech": "adjective",
      "translations": ["cold", "cool"],
      "relatedTagalog": "malamig",
      "examples": [
        {"kp": "Marimla ya ing danum king baldi.", "en": "The water in the bucket is cold."},
        {"kp": "Marimla ing bengi.", "en": "The night is cold."}
      ],
      "notes": "From ma- + dimla. Confirmed in Wiktionary. Also listed as 'marimla' in tagaloglang.com and pdfcoffee vocabulary sources."
    },
    {
      "id": "col-malagu",
      "word": "Malagu",
      "partOfSpeech": "adjective",
      "translations": ["beautiful"],
      "relatedTagalog": "maganda",
      "examples": [
        {"kp": "Malagu ya ing babai.", "en": "The woman is beautiful."},
        {"kp": "Malagu ing bulaklak.", "en": "The flower is beautiful."}
      ],
      "notes": "From ma- + lagu. Traditionally used to describe feminine beauty, though also used for things. Synonyms include masampat and masanting. Confirmed in multiple sources."
    },
    {
      "id": "col-masanting",
      "word": "Masanting",
      "partOfSpeech": "adjective",
      "translations": ["handsome", "good-looking", "nice"],
      "relatedTagalog": "gwapo",
      "examples": [
        {"kp": "Masanting ya ing lalaki.", "en": "The man is handsome."},
        {"kp": "Masanting ka talaga.", "en": "You are really handsome."}
      ],
      "notes": "Traditionally used to describe masculine attractiveness, contrasting with malagu. Also listed as a synonym of malagu in Wiktionary. Confirmed in tagaloglang.com and multiple conversational sources."
    },
    {
      "id": "col-bayu",
      "word": "Bayu",
      "partOfSpeech": "adjective",
      "translations": ["new"],
      "relatedTagalog": "bago",
      "examples": [
        {"kp": "Bayu ya ing libru ku.", "en": "My book is new."},
        {"kp": "Bayu ing kotse na.", "en": "His car is new."}
      ],
      "notes": "Confirmed in Wiktionary as adjective meaning 'new (recently made or created)'. Cognate with Tagalog bago, Ilocano baro. Antonym: matua."
    },
    {
      "id": "col-matua",
      "word": "Matua",
      "partOfSpeech": "adjective",
      "translations": ["old", "aged"],
      "relatedTagalog": "matanda",
      "examples": [
        {"kp": "Matua ya ing pari.", "en": "The priest is old."},
        {"kp": "Matua ya ing bale da.", "en": "Their house is old."}
      ],
      "notes": "Confirmed in Wiktionary. Primary sense is 'old/aged/elderly', most naturally applied to people but extended to things in common usage. Antonym: bayu. Proto-Malayo-Polynesian origin."
    },
    {
      "id": "col-matas",
      "word": "Matas",
      "partOfSpeech": "adjective",
      "translations": ["tall", "high"],
      "relatedTagalog": "mataas",
      "examples": [
        {"kp": "Matas ya ing puno.", "en": "The tree is tall."},
        {"kp": "Matas ing bunduk.", "en": "The mountain is high."}
      ],
      "notes": "From ma- + tas. Cognate with Tagalog mataas. Confirmed in Wiktionary. Refers to vertical height."
    },
    {
      "id": "col-makaba",
      "word": "Makaba",
      "partOfSpeech": "adjective",
      "translations": ["long"],
      "relatedTagalog": "mahaba",
      "examples": [
        {"kp": "Makaba ya ing dalan.", "en": "The road is long."},
        {"kp": "Makaba ing buhuk na.", "en": "Her hair is long."}
      ],
      "notes": "From ma- + kaba. Confirmed in Wiktionary and tagaloglang.com Kapampangan dictionary."
    },
    {
      "id": "col-makuyad",
      "word": "Makuyad",
      "partOfSpeech": "adjective",
      "translations": ["short"],
      "relatedTagalog": "maikli",
      "examples": [
        {"kp": "Makuyad ya ing lapis.", "en": "The pencil is short."},
        {"kp": "Makuyad ing kwentu na.", "en": "His story is short."}
      ],
      "notes": "Confirmed in tagaloglang.com Kapampangan dictionary as the translation of Tagalog maigsi/maikli. Consistent across multiple vocabulary sources."
    },
    {
      "id": "col-matsura",
      "word": "Matsura",
      "partOfSpeech": "adjective",
      "translations": ["ugly"],
      "relatedTagalog": "pangit",
      "examples": [
        {"kp": "Matsura ya ing larawan.", "en": "The picture is ugly."},
        {"kp": "Ali matsura ing bale da.", "en": "Their house is not ugly."}
      ],
      "notes": "Confirmed in tagaloglang.com and pdfcoffee vocabulary sources as the Kapampangan word for 'ugly' (Tagalog pangit). Used in contrast with malagu and masanting."
    }
  ],
