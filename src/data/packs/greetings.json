{
  "id": "greetings",
  "title": "Greetings & Courtesy",
  "entries": [
    {
      "id": "greet-mayap-a-abak",
      "word": "Mayap a abak",
      "partOfSpeech": "phrase",
      "translations": [
        "good morning"
      ],
      "relatedTagalog": "magandang umaga",
      "examples": [
        {
          "kp": "Mayap a abak, Tatang!",
          "en": "Good morning, Father!"
        },
        {
          "kp": "Mayap a abak pu keka.",
          "en": "Good morning to you (respectful)."
        }
      ],
      "notes": "Literally 'good morning'. Add 'pu' after the phrase to show respect to elders."
    },
    {
      "id": "greet-mayap-a-gatpanapun",
      "word": "Mayap a gatpanapun",
      "partOfSpeech": "phrase",
      "translations": [
        "good afternoon"
      ],
      "relatedTagalog": "magandang hapon",
      "examples": [
        {
          "kp": "Mayap a gatpanapun keka!",
          "en": "Good afternoon to you!"
        },
        {
          "kp": "Mayap a gatpanapun, Ima.",
          "en": "Good afternoon, Mother."
        }
      ],
      "notes": "Standard afternoon greeting. 'Gatpanapun' means afternoon in Kapampangan."
    },
    {
      "id": "greet-mayap-a-bengi",
      "word": "Mayap a bengi",
      "partOfSpeech": "phrase",
      "translations": [
        "good evening",
        "good night"
      ],
      "relatedTagalog": "magandang gabi",
      "examples": [
        {
          "kp": "Mayap a bengi, kaklase!",
          "en": "Good evening, classmate!"
        },
        {
          "kp": "Mayap a bengi pu, Ingkung.",
          "en": "Good evening, Grandfather (respectful)."
        }
      ],
      "notes": "Used both as an evening greeting and a parting phrase at night. 'Bengi' means night/evening."
    },
    {
      "id": "greet-paalam",
      "word": "Paalam",
      "partOfSpeech": "interjection",
      "translations": [
        "goodbye",
        "farewell"
      ],
      "relatedTagalog": "paalam",
      "examples": [
        {
          "kp": "Paalam na ku!",
          "en": "I'm saying goodbye now!"
        },
        {
          "kp": "Paalam, Tatang. Balik naku mamaya.",
          "en": "Goodbye, Father. I'll be back later."
        }
      ],
      "notes": "From Spanish 'para Alá'. Used when leaving; same form as Tagalog. A shared loanword across Philippine languages."
    },
    {
      "id": "greet-patawad-na",
      "word": "Patawad na",
      "partOfSpeech": "phrase",
      "translations": [
        "sorry",
        "please forgive me",
        "I'm sorry"
      ],
      "relatedTagalog": "patawad / pasensya na",
      "examples": [
        {
          "kp": "Patawad na, e ku iti ginawa karing sala.",
          "en": "Sorry, I didn't mean to make a mistake."
        },
        {
          "kp": "Patawad na, naulagang ku.",
          "en": "I'm sorry, I forgot."
        }
      ],
      "notes": "A sincere apology phrase. 'Patawad' means forgiveness; 'na' softens the request."
    },
    {
      "id": "greet-makilabas-ku",
      "word": "Makilabas ku",
      "partOfSpeech": "phrase",
      "translations": [
        "excuse me",
        "pardon me"
      ],
      "relatedTagalog": "makikiraan / excuse me",
      "examples": [
        {
          "kp": "Makilabas ku pu, munta ku na.",
          "en": "Excuse me, I'm going already."
        },
        {
          "kp": "Makilabas ku, ali ku iti naintindihan.",
          "en": "Excuse me, I didn't understand that."
        }
      ],
      "notes": "Used when politely asking to pass through or excusing oneself. Adding 'pu' makes it more respectful."
    },
    {
      "id": "greet-malaus-ko-pu",
      "word": "Malaus ko pu",
      "partOfSpeech": "phrase",
      "translations": [
        "welcome",
        "please come in"
      ],
      "relatedTagalog": "tuloy kayo / maligayang pagdating",
      "examples": [
        {
          "kp": "Malaus ko pu, mangan kamu deni!",
          "en": "Welcome, please eat here!"
        },
        {
          "kp": "Malaus ka pu king bale mi.",
          "en": "Welcome to our home."
        }
      ],
      "notes": "Warm hospitality phrase. Literally 'please proceed in'. 'Kayu' replaces 'ko' when addressing multiple guests."
    },
    {
      "id": "greet-mimingat",
      "word": "Mimingat",
      "partOfSpeech": "phrase",
      "translations": [
        "take care",
        "be careful"
      ],
      "relatedTagalog": "ingat",
      "examples": [
        {
          "kp": "Mimingat ka keraklan!",
          "en": "Take care always!"
        },
        {
          "kp": "Paalam na, Mimingat ka pu.",
          "en": "Goodbye, take care (respectful)."
        }
      ],
      "notes": "Said when parting with someone as a caring farewell. Equivalent to 'ingat' in Tagalog."
    },
    {
      "id": "greet-alang-nanu-naman",
      "word": "Alang nanu naman",
      "partOfSpeech": "phrase",
      "translations": [
        "you're welcome",
        "it's nothing",
        "don't mention it"
      ],
      "relatedTagalog": "walang anuman",
      "examples": [
        {
          "kp": "\"Dakal a salamat!\" \"Alang nanu naman.\"",
          "en": "\"Thank you very much!\" \"You're welcome.\""
        },
        {
          "kp": "Alang nanu naman, kaluguran.",
          "en": "It's nothing, friend."
        }
      ],
      "notes": "The standard response to 'salamat' (thank you). Literally 'there is nothing at all'."
    },
    {
      "id": "greet-pagmananwan",
      "word": "Págmanánwan",
      "partOfSpeech": "interjection",
      "translations": [
        "congratulations"
      ],
      "relatedTagalog": "maligayang bati",
      "examples": [
        {
          "kp": "Págmanánwan daká!",
          "en": "Congratulations to you!"
        },
        {
          "kp": "Págmanánwan keka king panalung mu.",
          "en": "Congratulations on your victory."
        }
      ],
      "notes": "Attested on Tatoeba as the Kapampangan equivalent of 'Congratulations!'. 'Daká' means 'to you'."
    },
    {
      "id": "greet-tara-na",
      "word": "Tara na",
      "partOfSpeech": "phrase",
      "translations": [
        "let's go",
        "come on, let's go"
      ],
      "relatedTagalog": "tara na / halika na",
      "examples": [
        {
          "kp": "Tara na, atulan na kaming dalan.",
          "en": "Let's go, we'll be late."
        },
        {
          "kp": "Tara na, munta tana kang mangan!",
          "en": "Let's go, let's go eat!"
        }
      ],
      "notes": "Common informal phrase used to prompt someone to leave or start moving. Also used as 'Tara' alone."
    },
    {
      "id": "greet-mikit-tana",
      "word": "Mikit tana",
      "partOfSpeech": "phrase",
      "translations": [
        "see you",
        "see you later",
        "see you next time"
      ],
      "relatedTagalog": "magkita tayo",
      "examples": [
        {
          "kp": "Mikit tana keng tutuki!",
          "en": "See you next time!"
        },
        {
          "kp": "Paalam na, Mikit tana mamaya.",
          "en": "Goodbye, see you later."
        }
      ],
      "notes": "A farewell phrase. 'Mikit' comes from the root 'ikit' (to see/meet). 'Tana' means 'let us'."
    },
    {
      "id": "greet-malyari",
      "word": "Malyari",
      "partOfSpeech": "particle",
      "translations": [
        "please (may I/could you)",
        "may I",
        "is it possible"
      ],
      "relatedTagalog": "puwede / maaari",
      "examples": [
        {
          "kp": "Malyari mu akung tulungan?",
          "en": "Could you please help me?"
        },
        {
          "kp": "Malyari ku pong makilabas?",
          "en": "May I please go out?"
        }
      ],
      "notes": "Used to make polite requests. Equivalent to 'puwede' or 'maaari' in Tagalog. Often precedes a verb."
    },
    {
      "id": "greet-dispus",
      "word": "Dispû",
      "partOfSpeech": "interjection",
      "translations": [
        "hello",
        "hi (respectful response)"
      ],
      "relatedTagalog": "kumusta / mano po",
      "examples": [
        {
          "kp": "Dispû, Apu! Mayap a abak!",
          "en": "Hello, Grandma! Good morning!"
        },
        {
          "kp": "Dispû! Kumusta na ka?",
          "en": "Hello! How are you?"
        }
      ],
      "notes": "A respectful greeting used especially toward elders. Wikivoyage lists this as the standard Kapampangan hello."
    },
    {
      "id": "greet-masayang-kebaitan",
      "word": "Masayang kebaitan",
      "partOfSpeech": "phrase",
      "translations": [
        "happy birthday"
      ],
      "relatedTagalog": "maligayang kaarawan",
      "examples": [
        {
          "kp": "Masayang kebaitan keka!",
          "en": "Happy birthday to you!"
        },
        {
          "kp": "Masayang kebaitan, Ima!",
          "en": "Happy birthday, Mother!"
        }
      ],
      "notes": "The standard Kapampangan birthday greeting. 'Kebaitan' means birthday/birth anniversary."
    }
  ],
