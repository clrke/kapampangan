{
  "id": "daily",
  "title": "Daily Life",
  "entries": [
    {
      "id": "dl-trabahu",
      "word": "trabahu",
      "partOfSpeech": "noun",
      "translations": [
        "work",
        "job",
        "labor"
      ],
      "relatedTagalog": "trabaho",
      "examples": [
        {
          "kp": "Maragul ing trabahu ku king abak.",
          "en": "My work is heavy in the morning."
        },
        {
          "kp": "Malambat ya ing trabahu na.",
          "en": "His work is slow."
        }
      ],
      "notes": "'trabahu' refers to a job or employment. Contrast with 'gawa', which is the result or act of doing something."
    },
    {
      "id": "dl-panahon",
      "word": "panahon",
      "partOfSpeech": "noun",
      "translations": [
        "weather",
        "time",
        "season"
      ],
      "relatedTagalog": "panahon",
      "examples": [
        {
          "kp": "Mapali ing panahon ngeni.",
          "en": "The weather is hot today."
        },
        {
          "kp": "Mayap ing panahon ngeni para king byahe.",
          "en": "The weather is good today for travel."
        }
      ],
      "notes": "'panahon' covers both weather and a span of time or season; context clarifies the meaning."
    },
    {
      "id": "dl-gawa",
      "word": "gawa",
      "partOfSpeech": "noun",
      "translations": [
        "task",
        "deed",
        "work",
        "act"
      ],
      "relatedTagalog": "gawa",
      "examples": [
        {
          "kp": "Ing babagwa gumawa ya ning gawa na.",
          "en": "The spider makes its web."
        },
        {
          "kp": "Mayap ing gawa na.",
          "en": "His deed is good."
        }
      ],
      "notes": "'gawa' is the result or act of doing; 'trabahu' refers to employment or a job."
    },
    {
      "id": "dl-byahe",
      "word": "byahe",
      "partOfSpeech": "noun",
      "translations": [
        "trip",
        "journey",
        "travel"
      ],
      "relatedTagalog": "biyahe",
      "examples": [
        {
          "kp": "Atlung aldo na ing byahe.",
          "en": "The trip is three days."
        },
        {
          "kp": "Malayo ing byahe da.",
          "en": "Their journey is far."
        }
      ]
    },
    {
      "id": "dl-daliri",
      "word": "daliri",
      "partOfSpeech": "noun",
      "translations": [
        "finger",
        "toe"
      ],
      "relatedTagalog": "daliri",
      "examples": [
        {
          "kp": "Lima la reng daliri ning kamut.",
          "en": "There are five fingers on the hand."
        },
        {
          "kp": "Masakit ya ing daliri ku.",
          "en": "My finger hurts."
        }
      ],
      "notes": "'daliri' is used for both fingers and toes; context or a qualifier clarifies (daliri ning kamut = finger, daliri ning paa = toe)."
    },
    {
      "id": "dl-gutom",
      "word": "gutom",
      "partOfSpeech": "adjective",
      "translations": [
        "hungry"
      ],
      "relatedTagalog": "gutom",
      "examples": [
        {
          "kp": "Gutom ya ing atyan ku.",
          "en": "My stomach is hungry."
        },
        {
          "kp": "Gutom na ya ing anak.",
          "en": "The child is already hungry."
        }
      ]
    },
    {
