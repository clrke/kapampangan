      "relatedTagalog": "liham",
      "examples": [
        {
          "kp": "Susulat ku liham kaniya.",
          "en": "I am writing a letter to him/her."
        },
        {
          "kp": "Atin liham para keka king lamesa.",
          "en": "There is a letter for you on the table."
        }
      ],
      "notes": "Shared with Tagalog. Refers to a written letter or correspondence (not a letter of the alphabet). Attested in particles pack example sentences. Confidence: very high."
    },
    {
