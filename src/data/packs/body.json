{
  "id": "body",
  "title": "Body & Health",
  "entries": [
    {
      "id": "body-buntuk",
      "word": "buntuk",
      "partOfSpeech": "noun",
      "translations": [
        "head"
      ],
      "relatedTagalog": "ulo",
      "examples": [
        {
          "kp": "Masakit ya ing buntuk ku.",
          "en": "My head hurts."
        },
        {
          "kp": "Maragul ya ing buntuk na.",
          "en": "His head is big."
        }
      ],
      "notes": "Confirmed in ABVD Kapampangan wordlist, oocities body-parts list, and multiple vocabulary guides. Distinct from Tagalog 'ulo'."
    },
    {
      "id": "body-mata",
      "word": "mata",
      "partOfSpeech": "noun",
      "translations": [
        "eye"
      ],
      "relatedTagalog": "mata",
      "examples": [
        {
          "kp": "Maragul ya ing mata na.",
          "en": "Her eye is big."
        },
        {
          "kp": "Masakit ya ing mata ku ngeni.",
          "en": "My eye hurts today."
        }
      ],
      "notes": "Shared with Tagalog. Confirmed in ABVD, oocities list, Wikibooks Kapampangan/Nouns, and the Kapampangan Listorian body-parts blog post."
    },
    {
      "id": "body-balugbug",
      "word": "balugbug",
      "partOfSpeech": "noun",
      "translations": [
        "ear"
      ],
      "relatedTagalog": "tainga",
      "examples": [
        {
          "kp": "Ing balugbug ku masakit ya.",
          "en": "My ear is painful."
        },
        {
          "kp": "Dakal yang balugbug ing elepante.",
          "en": "The elephant has many ears."
        }
      ],
      "notes": "Confirmed in ABVD Kapampangan wordlist and oocities Kapampangan body-parts list. Distinct from Tagalog 'tainga'."
    },
    {
      "id": "body-arung",
      "word": "arung",
      "partOfSpeech": "noun",
      "translations": [
        "nose"
      ],
      "relatedTagalog": "ilong",
      "examples": [
        {
          "kp": "Malati ya ing arung na.",
          "en": "Her nose is small."
        },
        {
          "kp": "Ing arung ku napuputian ya king sakit.",
          "en": "My nose runs when I am sick."
        }
      ],
      "notes": "Confirmed in ABVD, oocities body-parts list, and multiple Kapampangan vocabulary guides. Distinct from Tagalog 'ilong'."
    },
    {
      "id": "body-asbuk",
      "word": "asbuk",
      "partOfSpeech": "noun",
      "translations": [
        "mouth"
      ],
      "relatedTagalog": "bibig",
      "examples": [
        {
          "kp": "Sarad mo ing asbuk mu.",
          "en": "Close your mouth."
        },
        {
          "kp": "Ing asbuk na maragul ya.",
          "en": "His mouth is big."
        }
      ],
      "notes": "Confirmed in ABVD (listed as 'asbuk'), oocities list ('asbuk/balungus'), Kapampangan idioms article ('bubula asbuk'). Distinct from Tagalog 'bibig'."
    },
    {
      "id": "body-ipan",
      "word": "ipan",
      "partOfSpeech": "noun",
      "translations": [
        "tooth",
        "teeth"
      ],
      "relatedTagalog": "ngipin",
      "examples": [
        {
          "kp": "Maputi ya ing ipan na.",
          "en": "Her teeth are white."
        },
        {
          "kp": "Masakit ya ing ipan ku.",
          "en": "My tooth hurts."
        }
      ],
      "notes": "Confirmed in ABVD ('ipan'), oocities list ('ipan'), and Kapampangan body parts Quizlet sets. Distinct from Tagalog 'ngipin'."
    },
    {
      "id": "body-buak",
      "word": "buak",
      "partOfSpeech": "noun",
      "translations": [
        "hair"
      ],
      "relatedTagalog": "buhok",
      "examples": [
        {
          "kp": "Malutu ya ing buak na.",
          "en": "Her hair is red."
        },
        {
          "kp": "Makaba ya ing buak na.",
          "en": "Her hair is long."
        }
      ],
      "notes": "Confirmed in ABVD ('buak'), oocities list ('buak'), tagaloglang.com ('bwak' variant), and Sunstar Kapampangan articles. Distinct from Tagalog 'buhok'."
    },
    {
      "id": "body-gamat",
      "word": "gamat",
      "partOfSpeech": "noun",
      "translations": [
        "hand"
      ],
      "relatedTagalog": "kamay",
      "examples": [
        {
          "kp": "Hugasan me ing gamat mu.",
          "en": "Wash your hand."
        },
        {
          "kp": "Masakit ya ing gamat ku.",
          "en": "My hand hurts."
        }
      ],
      "notes": "Confirmed in ABVD ('gámat'), oocities list ('gamat'), Kapampangan idioms article ('magatal gamat' = itchy hands), and Sunstar Kapampangan articles. Distinct from Tagalog 'kamay'."
    },
    {
      "id": "body-bitis",
      "word": "bitis",
      "partOfSpeech": "noun",
      "translations": [
        "foot",
        "leg"
      ],
      "relatedTagalog": "paa",
      "examples": [
        {
          "kp": "Masakit ya ing bitis ku.",
          "en": "My foot hurts."
        },
        {
          "kp": "Mapali ya ing bitis na nung maniarikit ya.",
          "en": "Her legs are fast when she runs."
        }
      ],
      "notes": "Confirmed in oocities list ('bitis' = feet), Sunstar Kapampangan article, and Kapampangan idioms ('maburak a bitis' = muddy feet, meaning poor). Distinct from Tagalog 'paa'."
    },
    {
      "id": "body-pusu",
      "word": "pusu",
      "partOfSpeech": "noun",
      "translations": [
        "heart"
      ],
      "relatedTagalog": "puso",
      "examples": [
        {
          "kp": "Tibuk ya ing pusu ku.",
          "en": "My heart beats."
        },
        {
          "kp": "Malusug ya ing pusu ku.",
          "en": "My heart is healthy."
        }
      ],
      "notes": "Confirmed in oocities list ('pusu'), Sunstar Kapampangan article, and Vocabulario Pampango-Tagalog-Inglés ('pusuo'). Related to Tagalog 'puso'."
    },
    {
      "id": "body-atyan",
      "word": "atyan",
      "partOfSpeech": "noun",
      "translations": [
        "stomach",
        "belly"
      ],
      "relatedTagalog": "tiyan",
      "examples": [
        {
          "kp": "Masakit ya ing atyan ku.",
          "en": "My stomach hurts."
        },
        {
          "kp": "Gutom ya ing atyan ku.",
          "en": "My stomach is hungry."
        }
      ],
      "notes": "Confirmed in ABVD ('atian/atsan'), oocities list ('atyan'), Kapampangan idioms article ('pangaduang atyan'), Wikivoyage phrasebook ('masakit ku atyan'). Related to Tagalog 'tiyan'."
    },
    {
      "id": "body-daya",
      "word": "daya",
      "partOfSpeech": "noun",
      "translations": [
        "blood"
      ],
      "relatedTagalog": "dugo",
      "examples": [
        {
          "kp": "Atyu ya ing daya king gamat ku.",
          "en": "There is blood on my hand."
        },
        {
          "kp": "Malutu ya ing daya.",
          "en": "Blood is red."
        }
      ],
      "notes": "Confirmed in ABVD ('dáyâ'), archive.org Vocabulario Pampango-Tagalog-Inglés ('daya'), and Sunstar Kapampangan article (Garcia, katawan/kaladwa piece). Distinct from Tagalog 'dugo'."
    },
    {
      "id": "body-masakit",
      "word": "masakit",
      "partOfSpeech": "adjective",
      "translations": [
        "sick",
        "ill",
        "painful",
        "hurt"
      ],
      "relatedTagalog": "masakit",
      "examples": [
        {
          "kp": "Masakit ku yata.",
          "en": "I think I am sick."
        },
        {
          "kp": "Ing atyan ku masakit ya.",
          "en": "My stomach is painful."
        }
      ],
      "notes": "Confirmed in Wiktionary Kapampangan entry, kaikki.org dictionary, and Wikivoyage phrasebook ('Másakit ku' = I'm sick). Formed from ma- + sakit. Shared with Tagalog."
    },
    {
      "id": "body-sakit",
      "word": "sakit",
      "partOfSpeech": "noun",
      "translations": [
        "illness",
        "sickness",
        "pain",
        "disease"
      ],
      "relatedTagalog": "sakit",
      "examples": [
        {
          "kp": "Maragul a sakit ya iti.",
          "en": "This is a serious illness."
        },
        {
          "kp": "Nung ati kang sakit, munta ka king doktor.",
          "en": "If you have an illness, go to the doctor."
        }
      ],
      "notes": "Confirmed in Wikivoyage phrasebook, Austronesian Comparative Dictionary (*sakit cognate set), and multiple Kapampangan health articles. Root of 'masakit'. Shared with Tagalog."
    },
    {
      "id": "body-doktor",
      "word": "doktor",
      "partOfSpeech": "noun",
      "translations": [
        "doctor",
        "physician"
      ],
      "relatedTagalog": "doktor",
      "examples": [
        {
          "kp": "Mangailangan kung doktor.",
          "en": "I need a doctor."
        },
        {
          "kp": "Ing doktor tutulungan ya keka.",
          "en": "The doctor will help you."
        }
      ],
      "notes": "Confirmed in Wikivoyage Kapampangan phrasebook ('Mangailangan kung doktor'). Spanish/English loanword universally used across Philippine languages including Kapampangan."
    },
    {
      "id": "body-gamut",
      "word": "gamut",
      "partOfSpeech": "noun",
      "translations": [
        "medicine",
        "remedy",
        "treatment"
      ],
      "relatedTagalog": "gamot",
      "examples": [
        {
          "kp": "Kailangan ko ning gamut para king sakit ku.",
          "en": "I need medicine for my illness."
        },
        {
          "kp": "Ibyan na king doktor ing gamut.",
          "en": "The doctor gave the medicine."
        }
      ],
      "notes": "Attested in the Vocabulario Pampango-Tagalog-Inglés and Wikivoyage compound 'panulung' forms (panulung lagnat = cold medicine). 'Gamut' is the Kapampangan form cognate with Tagalog 'gamot'. Also seen in 'pakalako sakit' (pain reliever) usage in Wikivoyage."
    },
    {
      "id": "body-mapagal",
      "word": "mapagal",
      "partOfSpeech": "adjective",
      "translations": [
        "tired",
        "weary",
        "exhausted"
      ],
      "relatedTagalog": "pagod",
      "examples": [
        {
          "kp": "Mapagal na ku.",
          "en": "I am already tired."
        },
        {
          "kp": "Ing doktor mapagal ya nung tapos na ing maluad a dake.",
          "en": "The doctor is tired when the long day is done."
        }
      ],
      "notes": "Confirmed in archive.org Vocabulario Pampango-Tagalog-Inglés ('mapagal' = tired), Facebook LinyangKapampangan post ('kapagal ko' variant), and Sunstar health article. Root 'pagal' shared with other Philippine languages."
    },
    {
      "id": "body-malusug",
      "word": "malusug",
      "partOfSpeech": "adjective",
      "translations": [
        "healthy",
        "well",
        "in good health"
      ],
      "relatedTagalog": "malusog",
      "examples": [
        {
          "kp": "Malusug ku ngeni.",
          "en": "I am healthy now."
        },
        {
          "kp": "Ing katawan na malusug ya.",
          "en": "His body is healthy."
        }
      ],
      "notes": "Confirmed in Sunstar Pampanga article headline 'Pamagdatilang Masikan at Malusug king Kabilyan Ngeni' (Staying Strong and Healthy). Related to Tagalog 'malusog'. Formed from ma- + lusug (healthy/nourished)."
    },
    {
      "id": "body-paa",
      "word": "paa",
      "partOfSpeech": "noun",
      "translations": ["foot", "paw", "feet"],
      "relatedTagalog": "paa",
      "examples": [
        {"kp": "Apat a paa ning aso.", "en": "A dog has four paws."},
        {"kp": "Masakit ya ing paa ku.", "en": "My foot hurts."}
      ],
      "notes": "Used especially for animal feet/paws ('apat a paa ning aso' = four paws of the dog). For human feet and legs, the more specifically Kapampangan word is 'bitis'."
    },
    {
      "id": "body-buhuk",
      "word": "buhuk",
      "partOfSpeech": "noun",
      "translations": [
        "hair (of the head)",
        "hair"
      ],
      "relatedTagalog": "buhok",
      "examples": [
        {
          "kp": "Maitum ya ing buhuk na.",
          "en": "Her hair is black."
        },
        {
          "kp": "Malaba ya ing buhuk na.",
          "en": "Her hair is long."
        }
      ],
      "notes": "The standard Kapampangan word for head hair. The Kapampangan form 'buhuk' contrasts with Tagalog 'buhok'. Confirmed in multiple Kapampangan body-parts vocabulary lists and the Dialects101 Kapampangan body parts resource. Refers specifically to hair of the head."
    },
    {
      "id": "body-balat",
      "word": "balat",
      "partOfSpeech": "noun",
      "translations": ["skin", "peel", "bark", "hide"],
      "relatedTagalog": "balat / balat (balat ng prutas)",
      "examples": [
        {
          "kp": "Maluad ya ing balat na.",
          "en": "His/her skin is smooth."
        },
        {
          "kp": "Maitum ya ing balat ning prutas.",
          "en": "The skin of the fruit is dark."
        }
      ],
      "notes": "Native Kapampangan word shared with Tagalog. Means skin (of a person or animal), peel (of fruit), or bark (of a tree). The same root covers skin and outer covering broadly."
    },
    {
      "id": "body-kamut",
      "word": "kamut",
      "partOfSpeech": "noun",
      "translations": ["hand", "hands"],
      "relatedTagalog": "kamay",
      "examples": [
        {
          "kp": "Hugasan me ing kamut mu.",
          "en": "Wash your hands."
        },
        {
          "kp": "Masakit ya ing kamut ku.",
          "en": "My hand hurts."
        }
      ],
      "notes": "Dialectal/variant form of 'gamat' (hand) used in certain Kapampangan-speaking communities. Both 'gamat' and 'kamut' are attested as the Kapampangan word for hand. Equivalent to Tagalog 'kamay'."
    }
  ],
