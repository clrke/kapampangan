{
  "id": "questions",
  "title": "Questions & Pointing Words",
  "entries": [
    {
      "id": "ask-ninu",
      "word": "ninu",
      "partOfSpeech": "pronoun",
      "translations": ["who"],
      "relatedTagalog": "sino",
      "examples": [
        {"kp": "Ninu ya ing tau ita?", "en": "Who is that person?"},
        {"kp": "Ninu la reng lalaki karin?", "en": "Who are those men there?"}
      ],
      "notes": "Confirmed in Wikipedia Kapampangan language article and HandWiki. Standard interrogative pronoun for persons. Example 'Ninu la reng lalaki?' is attested in Wikipedia."
    },
    {
      "id": "ask-nanu",
      "word": "nanu",
      "partOfSpeech": "pronoun",
      "translations": ["what"],
      "relatedTagalog": "ano",
      "examples": [
        {"kp": "Nanu ya ing gagawan mu?", "en": "What are you doing?"},
        {"kp": "Nanu ya ing lagyu mu?", "en": "What is your name?"}
      ],
      "notes": "Core question word. Attested on Wikipedia, HandWiki, tagaloglang.com, and the bryanquiroz22 grammar guide. Example 'Nanu ya ing gagawan mu?' is widely attested."
    },
    {
      "id": "ask-nukarin",
      "word": "nukarin",
      "partOfSpeech": "adverb",
      "translations": ["where"],
      "relatedTagalog": "nasaan",
      "examples": [
        {"kp": "Nukarin ya ing drayber?", "en": "Where is the driver?"},
        {"kp": "Nukarin ka munta?", "en": "Where are you going?"}
      ],
      "notes": "Standard locative question word. Attested in Wikipedia and HandWiki. Also spelled 'nokarin' in some sources; 'nukarin' is the dominant modern spelling. Do not confuse with 'karin' (there), which is its demonstrative counterpart."
    },
    {
      "id": "ask-kapilan",
      "word": "kapilan",
      "partOfSpeech": "adverb",
      "translations": ["when"],
      "relatedTagalog": "kailan",
      "examples": [
        {"kp": "Kapilan ya ing pista?", "en": "When is the fiesta?"},
        {"kp": "Kapilan ka datang?", "en": "When will you arrive?"}
      ],
      "notes": "Attested in Wikipedia, HandWiki, and multiple Kapampangan vocabulary guides. Cognate with Tagalog kailan."
    },
    {
      "id": "ask-obakit",
      "word": "obakit",
      "partOfSpeech": "adverb",
      "translations": ["why"],
      "relatedTagalog": "bakit",
      "examples": [
        {"kp": "Obakit ati ka keni?", "en": "Why are you here?"},
        {"kp": "Obakit ka masakit?", "en": "Why are you sick?"}
      ],
      "notes": "Attested in Wikipedia and HandWiki as the Kapampangan word for 'why'. The example 'Obakit ati ka keni?' is directly attested in Wikipedia. Also found as 'obat' in some registers. Cognate with Tagalog bakit."
    },
    {
      "id": "ask-makananu",
      "word": "makananu",
      "partOfSpeech": "adverb",
      "translations": ["how"],
      "relatedTagalog": "paano",
      "examples": [
        {"kp": "Makananu iti gawan?", "en": "How do you do this?"},
        {"kp": "Makananu ka datang keni?", "en": "How did you get here?"}
      ],
      "notes": "Attested in Wikipedia, HandWiki, tagaloglang.com, and bryanquiroz22 grammar guide. The example 'Makananu iti gawan?' is directly attested in Wikipedia. Distinct from kumusta (how are you) which is a greeting."
    },
    {
      "id": "ask-magkanu",
      "word": "magkanu",
      "partOfSpeech": "pronoun",
      "translations": ["how much"],
      "relatedTagalog": "magkano",
      "examples": [
        {"kp": "Magkanu ya ing metung a tinape?", "en": "How much is one bread?"},
        {"kp": "Magkanu ya iyan?", "en": "How much is that?"}
      ],
      "notes": "Attested in Wikipedia, HandWiki, and Wiktionary Category:Kapampangan pronouns. The example 'Magkanu ya ing metung a tinape?' is directly attested in Wikipedia. Covers 'how much' (price). Tagalog cognate is magkano."
    },
    {
      "id": "ask-kaninu",
      "word": "kaninu",
      "partOfSpeech": "pronoun",
      "translations": ["whose", "whom"],
      "relatedTagalog": "kanino",
      "examples": [
        {"kp": "Kaninu ya ing bag ini?", "en": "Whose bag is this?"},
        {"kp": "Kaninu me ibiye iyan?", "en": "To whom will you give that?"}
      ],
      "notes": "Attested in Wikipedia, HandWiki, and multiple grammar sources. Functions both as a possessive interrogative ('whose') and dative interrogative ('to whom'). The example 'Kaninu me ibiye iyan?' is directly attested in Wikipedia."
    },
    {
      "id": "ask-isanu",
      "word": "isanu",
      "partOfSpeech": "pronoun",
      "translations": ["which"],
      "relatedTagalog": "alin",
      "examples": [
        {"kp": "Isanu deti ya ing bisa ka?", "en": "Which of these do you want?"},
        {"kp": "Isanu ya ing mayap?", "en": "Which one is good?"}
      ],
      "notes": "Attested in Wikipedia and HandWiki. Also spelled 'isnanu' in some sources. The example 'Isanu deti ya ing bisa ka?' is directly attested in Wikipedia. Used to ask someone to choose from a set."
    },
    {
      "id": "ask-iyan",
      "word": "iyan",
      "partOfSpeech": "pronoun",
      "translations": ["that"],
      "relatedTagalog": "iyan",
      "examples": [
        {"kp": "Nanu ya iyan?", "en": "What is that?"},
        {"kp": "Malagu ya iyan.", "en": "That is beautiful."}
      ],
      "notes": "Demonstrative pronoun meaning 'that' (nearest to the addressee). Attested in Wikipedia, HandWiki, and the bryanquiroz22 grammar guide. Its locative form is 'oyan' (there, near addressee). Plural is 'den/ren'."
    },
    {
      "id": "ask-ita",
      "word": "ita",
      "partOfSpeech": "pronoun",
      "translations": ["that", "yonder", "that over there"],
      "relatedTagalog": "iyon",
      "examples": [
        {"kp": "Ninu ya ing tau ita?", "en": "Who is that person over there?"},
        {"kp": "Maragul ya ing bale ita.", "en": "That house over there is big."}
      ],
      "notes": "Remote demonstrative pronoun; refers to something far from both speaker and addressee. Attested in Wikipedia, HandWiki, and the bryanquiroz22 grammar guide. Plural is 'deta/reta'. Locative form is 'keta' or 'oyta'."
    },
    {
      "id": "ask-keni",
      "word": "keni",
      "partOfSpeech": "adverb",
      "translations": ["here"],
      "relatedTagalog": "dito",
      "examples": [
        {"kp": "Obakit ati ka keni?", "en": "Why are you here?"},
        {"kp": "Ati ya keni ing asu.", "en": "The dog is here."}
      ],
      "notes": "Locative demonstrative meaning 'here'. Attested in Wikipedia, HandWiki, and the bryanquiroz22 grammar guide. Specifically used when the addressee is not near the subject being spoken of. The example 'Obakit ati ka keni?' is directly attested in Wikipedia."
    },
    {
      "id": "ask-karin",
      "word": "karin",
      "partOfSpeech": "adverb",
      "translations": ["there"],
      "relatedTagalog": "doon",
      "examples": [
        {"kp": "Ninu la reng lalaki karin?", "en": "Who are those men there?"},
        {"kp": "Ati ya karin ing bale ku.", "en": "My house is there."}
      ],
      "notes": "Locative demonstrative meaning 'there' (near addressee). Attested in Wikipedia as a locative form ('karin/karen'). Also noted as a suffix/element of 'nukarin' (where). Distinct from 'nukarin' which is a question word."
    },
    {
      "id": "ask-oyan",
      "word": "oyan",
      "partOfSpeech": "adverb",
      "translations": ["there", "over there"],
      "relatedTagalog": "nandoon",
      "examples": [
        {"kp": "Oyan ya ing bale.", "en": "The house is over there."},
        {"kp": "Munta ka oyan.", "en": "Go over there."}
      ],
      "notes": "Existential/locative demonstrative meaning 'there' (near addressee). Attested in the bryanquiroz22 grammar guide and HandWiki as the existential counterpart of 'iyan'. Related to 'karin'. Plural is 'oren'."
    },
    {
      "id": "ask-nuanti",
      "word": "nuanti",
      "partOfSpeech": "adverb",
      "translations": ["how", "to what degree", "how much so"],
      "relatedTagalog": "gaano",
      "examples": [
        {"kp": "Nuanti ka kalagu?", "en": "How beautiful are you?"},
        {"kp": "Nuanti ya karimla?", "en": "How cold is it?"}
      ],
      "notes": "Attested in Wikipedia Kapampangan language article and HandWiki as a question word meaning 'to what degree'. The example 'Nuanti ka kalagu?' is directly attested in Wikipedia. Used to ask about the degree or extent of a quality, distinct from makananu (how — procedural) and magkanu (how much — price). Tagalog equivalent is gaano."
    }
  ],
