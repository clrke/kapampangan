{
  "id": "house",
  "title": "House & Home",
  "entries": [
    {
      "id": "house-bale",
      "word": "Bale",
      "partOfSpeech": "noun",
      "translations": ["house", "home"],
      "relatedTagalog": "bahay",
      "examples": [
        {"kp": "Maragul ya ing Bale mi.", "en": "Our house is big."},
        {"kp": "Atyu ku king Bale.", "en": "I am at home."}
      ],
      "notes": "The core Kapampangan word for house/home. Confirmed in Forman's Kapampangan Dictionary, tagaloglang.com, Wikivoyage phrasebook, and Kapampangan Traveller."
    },
    {
      "id": "house-pasbul",
      "word": "Pasbul",
      "partOfSpeech": "noun",
      "translations": ["door", "entrance"],
      "relatedTagalog": "pinto",
      "examples": [
        {"kp": "Sara me ing Pasbul.", "en": "Close the door."},
        {"kp": "Bukas ya ing Pasbul ning bale.", "en": "The door of the house is open."}
      ],
      "notes": "Consistently documented across multiple Kapampangan learning resources and vocabulary lists. Related verb: 'saraen' (to close)."
    },
    {
      "id": "house-awang",
      "word": "Awang",
      "partOfSpeech": "noun",
      "translations": ["window"],
      "relatedTagalog": "bintana",
      "examples": [
        {"kp": "Bukasan me ing Awang.", "en": "Open the window."},
        {"kp": "Malagus ya ing Awang.", "en": "The window is clear."}
      ],
      "notes": "Confirmed in Forman's dictionary, Wikivoyage phrasebook, and multiple vocabulary sources. The UCLA phonetics Kapampangan word list also attests this form."
    },
    {
      "id": "house-lamesa",
      "word": "Lamesa",
      "partOfSpeech": "noun",
      "translations": ["table"],
      "relatedTagalog": "mesa",
      "examples": [
        {"kp": "Atyu ing pamangan king Lamesa.", "en": "The food is on the table."},
        {"kp": "Lako ku king Lamesa.", "en": "I am going to the table."}
      ],
      "notes": "Spanish loanword (la mesa). Confirmed in speaking-kapampangan materials and multiple vocabulary lists. Also appears as 'mesa' in some sources; 'lamesa' is the standard full form."
    },
    {
      "id": "house-luklukan",
      "word": "Luklukan",
      "partOfSpeech": "noun",
      "translations": ["chair", "seat"],
      "relatedTagalog": "upuan",
      "examples": [
        {"kp": "Mika Luklukan ya ing anak.", "en": "The child has a chair."},
        {"kp": "Atyu ya king Luklukan ya.", "en": "He is on his chair."}
      ],
      "notes": "Confirmed in Wikibooks Kapampangan/Nouns, Kapampangan Traveller, and multiple vocabulary lists. From root 'luklu' (to sit)."
    },
    {
      "id": "house-pitudturan",
      "word": "Pitudturan",
      "partOfSpeech": "noun",
      "translations": ["bed"],
      "relatedTagalog": "higaan / kama",
      "examples": [
        {"kp": "Meturan ku king Pitudturan.", "en": "I lay down on the bed."},
        {"kp": "Maragul ya ing Pitudturan ku.", "en": "My bed is big."}
      ],
      "notes": "Confirmed in multiple Kapampangan vocabulary lists as the standard word for bed. Appears alongside pillow (ulnan) and blanket (ulas) in learning materials."
    },
    {
      "id": "house-kwartu",
      "word": "Kwartu",
      "partOfSpeech": "noun",
      "translations": ["room", "bedroom"],
      "relatedTagalog": "kwarto / silid",
      "examples": [
        {"kp": "Linisan me ing Kwartu.", "en": "Clean the room."},
        {"kp": "Atyu ya king Kwartu na.", "en": "He is in his room."}
      ],
      "notes": "Spanish loanword (cuarto). Confirmed in Wikivoyage Kapampangan phrasebook, Polytranslator, and multiple vocabulary sources."
    },
    {
      "id": "house-kusina",
      "word": "Kusina",
      "partOfSpeech": "noun",
      "translations": ["kitchen"],
      "relatedTagalog": "kusina",
      "examples": [
        {"kp": "Migluto ya king Kusina.", "en": "He cooked in the kitchen."},
        {"kp": "Maragul ya ing Kusina mi.", "en": "Our kitchen is big."}
      ],
      "notes": "Spanish loanword (cocina). Widely confirmed in Kapampangan texts and culinary references. Shared with Tagalog."
    },
    {
      "id": "house-sulu",
      "word": "Sulu",
      "partOfSpeech": "noun",
      "translations": ["light", "lamp"],
      "relatedTagalog": "ilaw",
      "examples": [
        {"kp": "Pasalan me ing Sulu.", "en": "Turn on the light."},
        {"kp": "Mabeyak ya ing Sulu king kwartu.", "en": "The light in the room is bright."}
      ],
      "notes": "Confirmed in multiple Kapampangan vocabulary sources including Kapampangan Traveller and a Facebook post from a Pampanga-based organization explicitly glossing 'sulu' as light/ilaw/liwanag."
    },
    {
      "id": "house-malan",
      "word": "Malan",
      "partOfSpeech": "noun",
      "translations": ["clothes", "clothing"],
      "relatedTagalog": "damit",
      "examples": [
        {"kp": "Labhan me ing Malan.", "en": "Wash the clothes."},
        {"kp": "Ating bayu kung Malan.", "en": "I have new clothes."}
      ],
      "notes": "Confirmed across multiple Kapampangan learning resources. The equivalent of Tagalog 'damit'."
    },
    {
      "id": "house-pader",
      "word": "Pader",
      "partOfSpeech": "noun",
      "translations": ["wall"],
      "relatedTagalog": "pader / dingding",
      "examples": [
        {"kp": "Makaputi ya ing Pader ning bale.", "en": "The wall of the house is white."},
        {"kp": "Migtutuk ya king Pader.", "en": "He leaned against the wall."}
      ],
      "notes": "Spanish loanword (pared). Confirmed in Kapampangan vocabulary lists and corroborated by usage on Facebook video captions using 'pader' in a Kapampangan context."
    },
    {
      "id": "house-atup",
      "word": "Atup",
      "partOfSpeech": "noun",
      "translations": ["roof"],
      "relatedTagalog": "bubong",
      "examples": [
        {"kp": "Mapula ya ing Atup ning bale mi.", "en": "The roof of our house is red."},
        {"kp": "Sinaul ya ing Atup.", "en": "The roof was repaired."}
      ],
      "notes": "Confirmed in the UCLA phonetics Kapampangan word list (1974) and multiple other sources. Also spelled 'atap' in some resources; 'atup' is the form in the UCLA phonetic transcription."
    },
    {
      "id": "house-lapag",
      "word": "Lapag",
      "partOfSpeech": "noun",
      "translations": ["floor"],
      "relatedTagalog": "sahig / lapag",
      "examples": [
        {"kp": "Linisan me ing Lapag.", "en": "Clean the floor."},
        {"kp": "Napalubus ya king Lapag.", "en": "He fell on the floor."}
      ],
      "notes": "Confirmed in multiple Kapampangan dictionary and vocabulary sources as the standard word for floor."
    },
    {
      "id": "house-platu",
      "word": "Platu",
      "partOfSpeech": "noun",
      "translations": ["plate", "dish"],
      "relatedTagalog": "plato / pinggan",
      "examples": [
        {"kp": "Hugasan me ing Platu.", "en": "Wash the plate."},
        {"kp": "Lagyan me nasi ing Platu.", "en": "Put rice on the plate."}
      ],
      "notes": "Spanish loanword (plato). Confirmed in Kapampangan-English vocabulary resources. Shared across Philippine languages."
    },
    {
      "id": "house-tasa",
      "word": "Tasa",
      "partOfSpeech": "noun",
      "translations": ["cup", "glass"],
      "relatedTagalog": "tasa / baso",
      "examples": [
        {"kp": "Pun me ing Tasa.", "en": "Fill the cup."},
        {"kp": "Bisa kung Tasa ning kape.", "en": "I want a cup of coffee."}
      ],
      "notes": "Spanish loanword (taza). Confirmed in Wikivoyage Kapampangan phrasebook and vocabulary lists. Refers to cup or drinking vessel."
    },
    {
      "id": "house-kutsara",
      "word": "Kutsara",
      "partOfSpeech": "noun",
      "translations": ["spoon"],
      "relatedTagalog": "kutsara",
      "examples": [
        {"kp": "Gamitan me ing Kutsara.", "en": "Use the spoon."},
        {"kp": "Nukarin ya ing Kutsara?", "en": "Where is the spoon?"}
      ],
      "notes": "Spanish loanword (cuchara). Confirmed across multiple Philippine language resources including Kapampangan vocabulary lists. Shared with Tagalog."
    },
    {
      "id": "house-kampit",
      "word": "Kampit",
      "partOfSpeech": "noun",
      "translations": ["knife"],
      "relatedTagalog": "kutsilyo",
      "examples": [
        {"kp": "Gamitan me ing Kampit.", "en": "Use the knife."},
        {"kp": "Atin Kampit king Kusina.", "en": "There is a knife in the kitchen."}
      ],
      "notes": "Confirmed in the Polytranslator Kapampangan dictionary. A distinctly Kapampangan word for knife, as opposed to the Spanish loanword 'kutsilyu' used in Tagalog."
    },
    {
      "id": "house-palis",
      "word": "Palis",
      "partOfSpeech": "noun",
      "translations": ["broom"],
      "relatedTagalog": "walis",
      "examples": [
        {"kp": "Gamitan me ing Palis.", "en": "Use the broom."},
        {"kp": "Palisan me ing lapag.", "en": "Sweep the floor with the broom."}
      ],
      "notes": "Confirmed in tagaloglang.com Kapampangan dictionary and multiple vocabulary lists. Related verb form 'palisan' means to sweep."
    }
  ],
