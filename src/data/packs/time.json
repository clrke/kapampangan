{
  "id": "time",
  "title": "Time & Calendar",
  "entries": [
    {
      "id": "time-aldo",
      "word": "aldo",
      "partOfSpeech": "noun",
      "translations": [
        "day",
        "sun"
      ],
      "relatedTagalog": "araw",
      "examples": [
        {
          "kp": "Mayap a aldo!",
          "en": "Good day!"
        },
        {
          "kp": "Maragul ya ing aldo ngeni.",
          "en": "The sun is big today."
        }
      ],
      "notes": "Means both 'day' and 'sun', parallel to Tagalog araw. Confirmed in Wikivoyage Kapampangan phrasebook and multiple vocabulary sources."
    },
    {
      "id": "time-bengi",
      "word": "bengi",
      "partOfSpeech": "noun",
      "translations": [
        "night",
        "evening"
      ],
      "relatedTagalog": "gabi",
      "examples": [
        {
          "kp": "Mayap a bengi!",
          "en": "Good evening!"
        },
        {
          "kp": "Marimla ing bengi ngeni.",
          "en": "The night is cold tonight."
        }
      ],
      "notes": "Confirmed in Wikivoyage phrasebook, tagaloglang.com, and the Kapampangan Traveller. Capitangang bengi means midnight."
    },
    {
      "id": "time-abak",
      "word": "abak",
      "partOfSpeech": "noun",
      "translations": [
        "morning"
      ],
      "relatedTagalog": "umaga",
      "examples": [
        {
          "kp": "Mayap a abak!",
          "en": "Good morning!"
        },
        {
          "kp": "Maragul ing trabahu ku king abak.",
          "en": "I have a lot of work in the morning."
        }
      ],
      "notes": "Refers to the period from dawn to midday. Confirmed in Wikivoyage phrasebook, Wikimedia Incubator Wiktionary entry, and tagaloglang.com. Also attested as 'abac' in older orthography."
    },
    {
      "id": "time-ugtu",
      "word": "ugtu",
      "partOfSpeech": "noun",
      "translations": [
        "noon",
        "midday"
      ],
      "relatedTagalog": "tanghali",
      "examples": [
        {
          "kp": "Mayap a ugtu!",
          "en": "Good noon!"
        },
        {
          "kp": "Mangan tamu king ugtu.",
          "en": "Let's eat at noon."
        }
      ],
      "notes": "Confirmed in Wikivoyage phrasebook, drakieness.blogspot.com, and Wikimedia Incubator entry for abak (which names ugtu as the midday boundary). Also cited as 'ogto' in older texts."
    },
    {
      "id": "time-gatpanapun",
      "word": "gatpanapun",
      "partOfSpeech": "noun",
      "translations": [
        "afternoon"
      ],
      "relatedTagalog": "hapon",
      "examples": [
        {
          "kp": "Mayap a gatpanapun!",
          "en": "Good afternoon!"
        },
        {
          "kp": "Mitalwi ya king gatpanapun.",
          "en": "He arrived late in the afternoon."
        }
      ],
      "notes": "Confirmed in Wikivoyage phrasebook and tagaloglang.com Kapampangan phrases. Used in the standard greeting 'Mayap a gatpanapun'."
    },
    {
      "id": "time-bulan",
      "word": "bulan",
      "partOfSpeech": "noun",
      "translations": [
        "month",
        "moon"
      ],
      "relatedTagalog": "buwan",
      "examples": [
        {
          "kp": "Malagu ya ing bulan ngeni.",
          "en": "The moon is beautiful tonight."
        },
        {
          "kp": "Pilan a bulan na?",
          "en": "How many months is it already?"
        }
      ],
      "notes": "Means both 'month' and 'moon', cognate with Tagalog buwan. Confirmed in Wikivoyage phrasebook and the Kapampangan Traveller vocabulary list."
    },
    {
      "id": "time-banwa",
      "word": "banwa",
      "partOfSpeech": "noun",
      "translations": [
        "year"
      ],
      "relatedTagalog": "taon",
      "examples": [
        {
          "kp": "Pilan na kang banwa?",
          "en": "How old are you? (lit. How many years are you?)"
        },
        {
          "kp": "Maragul ya ing banwa.",
          "en": "It has been a big year."
        }
      ],
      "notes": "Confirmed in Wikivoyage phrasebook and Wiktionary (as 'banua', with 'banwa' as the Sulat Wawa spelling). Wiktionary lists meanings: sky, heaven, glory, year, age. Derives from Proto-Malayo-Polynesian *banua."
    },
    {
      "id": "time-napun",
      "word": "napun",
      "partOfSpeech": "adverb",
      "translations": [
        "yesterday"
      ],
      "relatedTagalog": "kahapon",
      "examples": [
        {
          "kp": "Napasar ya napun.",
          "en": "He passed by yesterday."
        },
        {
          "kp": "Mapali ya ing panahon napun.",
          "en": "The weather was hot yesterday."
        }
      ],
      "notes": "Confirmed in Wikivoyage Kapampangan phrasebook as the standard word for 'yesterday'."
    },
    {
      "id": "time-bukas",
      "word": "bukas",
      "partOfSpeech": "adverb",
      "translations": [
        "tomorrow"
      ],
      "relatedTagalog": "bukas",
      "examples": [
        {
          "kp": "Munta tamu bukas.",
          "en": "Let's go tomorrow."
        },
        {
          "kp": "Maranun tamu bukas.",
          "en": "Let's be early tomorrow."
        }
      ],
      "notes": "Confirmed in Wikivoyage Kapampangan phrasebook. Shares the same form as Tagalog bukas (tomorrow). Not to be confused with uses meaning 'open' in other contexts."
    },
    {
      "id": "time-oras",
      "word": "oras",
      "partOfSpeech": "noun",
      "translations": [
        "hour",
        "time",
        "o'clock"
      ],
      "relatedTagalog": "oras",
      "examples": [
        {
          "kp": "Nanu na ing oras?",
          "en": "What time is it?"
        },
        {
          "kp": "Metung a oras na ing labas ku.",
          "en": "I have been outside for one hour."
        }
      ],
      "notes": "Loanword from Spanish hora. Confirmed in Wikivoyage phrasebook and the Kapampangan Traveller. Used for telling clock time and measuring hours."
    },
    {
      "id": "time-duminggu",
      "word": "duminggu",
      "partOfSpeech": "noun",
      "translations": [
        "week",
        "Sunday"
      ],
      "relatedTagalog": "linggo",
      "examples": [
        {
          "kp": "Ngening duminggu, marelax tamu.",
          "en": "This week, let's relax."
        },
        {
          "kp": "Munta taku simbahan king duminggu.",
          "en": "We go to church on Sunday."
        }
      ],
      "notes": "The word duminggu serves double duty as both 'week' and 'Sunday' in Kapampangan, just as Tagalog Linggo means both. Confirmed in Wikivoyage phrasebook ('ngening duminggu' = this week; 'Duminggu' = Sunday)."
    },
    {
      "id": "time-maranun",
      "word": "maranun",
      "partOfSpeech": "adjective",
      "translations": [
        "early"
      ],
      "relatedTagalog": "maaga",
      "examples": [
        {
          "kp": "Maranun ya ing dating na.",
          "en": "His arrival was early."
        },
        {
          "kp": "Maranun tamu bukas.",
          "en": "Let's be early tomorrow."
        }
      ],
      "notes": "Confirmed in the Kapampangan Traveller vocabulary list as the translation of 'early'. Used to describe arriving or doing something before expected time."
    },
    {
      "id": "time-pota",
      "word": "pota",
      "partOfSpeech": "adverb",
      "translations": [
        "later",
        "maybe later",
        "perhaps"
      ],
      "relatedTagalog": "mamaya",
      "examples": [
        {
          "kp": "Munta taku pota.",
          "en": "Let's go later."
        },
        {
          "kp": "Pota uran.",
          "en": "It might rain later."
        }
      ],
      "notes": "Confirmed in Wikivoyage phrasebook and the Kapampangan Traveller as meaning 'later'. Also carries a sense of uncertainty ('maybe'). Commonly used in everyday speech."
    },
    {
      "id": "time-mitalwi",
      "word": "mitalwi",
      "partOfSpeech": "verb",
      "translations": [
        "to arrive late",
        "to be late"
      ],
      "relatedTagalog": "mahuli",
      "examples": [
        {
          "kp": "Mitalwi ya king opisina.",
          "en": "He arrived late at the office."
        },
        {
          "kp": "Ali tamu mitalwi bukas.",
          "en": "Let's not be late tomorrow."
        }
      ],
      "notes": "Confirmed in the Kapampangan Traveller as the specific term for 'arrive late'. Distinct from simply being slow; specifically refers to arriving after the expected time."
    },
    {
      "id": "time-lunes",
      "word": "Lunes",
      "partOfSpeech": "noun",
      "translations": [
        "Monday"
      ],
      "relatedTagalog": "Lunes",
      "examples": [
        {
          "kp": "Trabahu taku king Lunes.",
          "en": "We work on Monday."
        },
        {
          "kp": "Maranun taku king Lunes.",
          "en": "Let's be early on Monday."
        }
      ],
      "notes": "Loanword from Spanish lunes. Confirmed in Wikivoyage Kapampangan phrasebook as the Kapampangan word for Monday."
    },
    {
      "id": "time-martes",
      "word": "Martes",
      "partOfSpeech": "noun",
      "translations": [
        "Tuesday"
      ],
      "relatedTagalog": "Martes",
      "examples": [
        {
          "kp": "Munta taku king Martes.",
          "en": "Let's go on Tuesday."
        },
        {
          "kp": "King Martes ya ing klase.",
          "en": "The class is on Tuesday."
        }
      ],
      "notes": "Loanword from Spanish martes. Confirmed in Wikivoyage Kapampangan phrasebook."
    },
    {
      "id": "time-myerkoles",
      "word": "Myerkoles",
      "partOfSpeech": "noun",
      "translations": [
        "Wednesday"
      ],
      "relatedTagalog": "Miyerkules",
      "examples": [
        {
          "kp": "Myerkoles ngeni.",
          "en": "It is Wednesday today."
        },
        {
          "kp": "Mangan taku king Myerkoles.",
          "en": "Let's eat together on Wednesday."
        }
      ],
      "notes": "Loanword from Spanish miércoles. Wikivoyage Kapampangan phrasebook spells this 'Myerkoles'. Tagalog uses Miyerkules."
    },
    {
      "id": "time-sabado",
      "word": "Sabado",
      "partOfSpeech": "noun",
      "translations": [
        "Saturday"
      ],
      "relatedTagalog": "Sabado",
      "examples": [
        {
          "kp": "Marelax taku king Sabado.",
          "en": "Let's relax on Saturday."
        },
        {
          "kp": "King Sabado, maranun tamu.",
          "en": "On Saturday, let's be early."
        }
      ],
      "notes": "Loanword from Spanish sábado. Confirmed in Wikivoyage Kapampangan phrasebook. One of the two weekend days alongside Duminggu."
    },
    {
      "id": "time-linggu",
      "word": "linggu",
      "partOfSpeech": "noun",
      "translations": [
        "week"
      ],
      "relatedTagalog": "linggo / sanlinggo",
      "examples": [
        {
          "kp": "Atlung linggu na.",
          "en": "It has been three weeks already."
        },
        {
          "kp": "Lima ya ing linggu.",
          "en": "There are five weeks."
        }
      ],
      "notes": "Derived from Spanish 'domingo' (Sunday), which in Kapampangan became the word for both Sunday (duminggu) and a week unit (linggu). Parallel to Tagalog 'linggo' for week."
    }
  ],
