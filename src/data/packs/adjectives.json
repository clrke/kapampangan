{
  "id": "adjectives",
  "title": "Adjectives",
  "entries": [
    {
      "id": "adj-maliwanag",
      "word": "maliwanag",
      "partOfSpeech": "adjective",
      "translations": [
        "bright",
        "clear",
        "luminous"
      ],
      "relatedTagalog": "maliwanag",
      "examples": [
        {
          "kp": "Maliwanag ya ing batuin king banua.",
          "en": "The stars are bright in the sky."
        },
        {
          "kp": "Bukasan me ing bintana para maliwanag ing kwartu.",
          "en": "Open the window so the room is bright."
        }
      ],
      "notes": "Used for light, clarity, brightness. 'Maliwanag ya ing aldo.' (The day is bright.)"
    },
    {
      "id": "adj-mainit",
      "word": "mainit",
      "partOfSpeech": "adjective",
      "translations": [
        "hot",
        "warm"
      ],
      "relatedTagalog": "mainit",
      "examples": [
        {
          "kp": "Mainit ya ing danum a ini.",
          "en": "This water is hot."
        },
        {
          "kp": "Mainit ya ing aldo ngeni.",
          "en": "The sun is hot today."
        }
      ],
      "notes": "'mainit' and 'mapali' are both used in Kapampangan; 'mainit' is especially common in spoken language."
    },
    {
      "id": "adj-malambat",
      "word": "malambat",
      "partOfSpeech": "adjective",
      "translations": [
        "slow"
      ],
      "relatedTagalog": "mabagal",
      "examples": [
        {
          "kp": "Takbu na ka, e ka malambat!",
          "en": "Run now, don't be slow!"
        },
        {
          "kp": "Malambat ya ing trabahu na.",
          "en": "His work is slow."
        }
      ],
      "notes": "Antonym of 'maliksi'."
    },
    {
      "id": "adj-maliksi",
      "word": "maliksi",
      "partOfSpeech": "adjective",
      "translations": [
        "fast",
        "quick",
        "agile"
      ],
      "relatedTagalog": "mabilis",
      "examples": [
        {
          "kp": "Ing angin maliksi ya.",
          "en": "The wind is fast."
        },
        {
          "kp": "Maliksi yang tumakbu ing anak.",
          "en": "The child runs fast."
        }
      ],
      "notes": "Antonym of 'malambat'."
    },
    {
      "id": "adj-malapit",
      "word": "malapit",
      "partOfSpeech": "adjective",
      "translations": [
        "near",
        "close"
      ],
      "relatedTagalog": "malapit",
      "examples": [
        {
          "kp": "Malapit ya ing dalan king balen.",
          "en": "The road is near the town."
        },
        {
          "kp": "Malapit ya ing tindahan keti.",
          "en": "The store is near here."
        }
      ],
      "notes": "Antonym of 'malayo'."
    },
    {
      "id": "adj-malayo",
      "word": "malayo",
      "partOfSpeech": "adjective",
      "translations": [
        "far",
        "distant"
      ],
      "relatedTagalog": "malayo",
      "examples": [
        {
          "kp": "Malayo ya ing dagat kareni.",
          "en": "The sea is far from here."
        },
        {
          "kp": "Malayo ya ing bale da.",
          "en": "Their house is far."
        }
      ],
      "notes": "Antonym of 'malapit'."
    },
    {
      "id": "adj-damu",
      "word": "damu",
      "partOfSpeech": "noun",
      "translations": [
        "grass",
        "weeds",
        "vegetation"
      ],
      "relatedTagalog": "damo",
      "examples": [
        {
          "kp": "Ing kambing makmak ya ning damu.",
          "en": "The goat grazes on the grass."
        },
        {
          "kp": "Dakal damu king bakuran.",
          "en": "There is a lot of grass in the yard."
        }
      ]
    },
    {
      "id": "adj-masipag",
      "word": "masipag",
      "partOfSpeech": "adjective",
      "translations": [
        "hardworking",
        "diligent",
        "industrious"
      ],
      "relatedTagalog": "masipag",
      "examples": [
        {
          "kp": "Ing tao masipag ya.",
          "en": "The person is hardworking."
        },
        {
          "kp": "Masipag ya ing anak da.",
          "en": "Their child is diligent."
        }
      ]
    },
    {
      "id": "adj-malupit",
      "word": "malupit",
      "partOfSpeech": "adjective",
      "translations": [
        "cruel",
        "harsh",
        "severe"
      ],
      "relatedTagalog": "malupit",
      "examples": [
        {
          "kp": "Malupit ya ing angin ngeni.",
          "en": "The wind is harsh today."
        },
        {
          "kp": "Malupit ya ing aldo ngeni.",
          "en": "The day is harsh today."
        }
      ]
    },
    {
      "id": "adj-masileng",
      "word": "masileng",
      "partOfSpeech": "adjective",
      "translations": [
        "careful",
        "cautious",
        "watchful"
      ],
      "relatedTagalog": "maingat",
      "examples": [
        {
          "kp": "Masileng tamu nung munta tamu karela.",
          "en": "Let's be careful when we go there."
        },
        {
          "kp": "Masileng ka king dalan.",
          "en": "Be careful on the road."
        }
      ]
    },
    {
      "id": "adj-guagua",
      "word": "guagua",
      "partOfSpeech": "adjective",
      "translations": ["small", "little", "young (of a person)"],
      "relatedTagalog": "maliit / bata",
      "examples": [
        {
          "kp": "Guagua pa ing Wali ku.",
          "en": "My younger sibling is still little."
        }
      ],
      "notes": "Adjective/stative predicate meaning 'small, little, young'. Used for people (especially children) and small things. 'Guagua pa' (still little/still young) is a common phrase. The Tagalog equivalent is 'maliit' (small) or 'bata' (young). Not to be confused with the place name Guagua (a town in Pampanga)."
    },
    {
      "id": "adj-sagiwa",
      "word": "sagiwa",
      "partOfSpeech": "adjective",
      "translations": ["fresh", "cool", "refreshing"],
      "relatedTagalog": "sariwa / malamig",
      "examples": [
        {
          "kp": "Sagiwa ya ing danum.",
          "en": "The water is fresh/cool."
        },
        {
          "kp": "Sagiwa ya ing panahon ngeni.",
          "en": "The weather is refreshing today."
        }
      ],
      "notes": "Native Kapampangan adjective meaning fresh, cool, or refreshing. Used for water, food, weather, and sensations. Attested in the Wikivoyage phrasebook as 'prutas sagiwa' (fresh fruit). The Tagalog equivalent is 'sariwa' (fresh) or 'malamig' (cool/cold)."
    },
    {
      "id": "adj-dakul",
      "word": "dakul",
      "partOfSpeech": "adjective",
      "translations": ["many", "a lot", "big", "large"],
      "relatedTagalog": "marami / malaki",
      "examples": [
        {
          "kp": "Dakul ya ing anak da.",
          "en": "They have many children."
        },
        {
          "kp": "Dakul a gulay king palengke ngeni.",
          "en": "There are many vegetables at the market today."
        }
      ],
      "notes": "Native Kapampangan word meaning 'many/a lot' or 'big/large' depending on context. Variant forms include dakal, dakol, and dakal. Used for quantity ('many') and size ('big'). Equivalent to Tagalog 'marami' (many) or 'malaki' (big)."
    },
    {
      "id": "adj-raku",
      "word": "raku",
      "partOfSpeech": "adjective",
      "translations": ["many", "numerous", "plenty"],
      "relatedTagalog": "marami",
      "examples": [
        {
          "kp": "Raku ya ing tindahan keti.",
          "en": "There are many stores here."
        },
        {
          "kp": "Raku la ing manuk king bakuran.",
          "en": "There are many chickens in the yard."
        }
      ],
      "notes": "Synonym/variant of dakal meaning 'many, numerous, plenty'. Used interchangeably with dakal and dakul in various Kapampangan dialects."
    },
    {
      "id": "adj-kanyaman",
      "word": "kanyaman",
      "partOfSpeech": "noun",
      "translations": ["comfort", "ease", "contentment", "feeling good"],
      "relatedTagalog": "kaginhawahan / kasiyahan",
      "examples": [
        {
          "kp": "Kanyaman ya king bale.",
          "en": "He/she feels comfortable at home."
        },
        {
          "kp": "Atin ku kanyaman ngeni.",
          "en": "I feel comfortable now."
        }
      ],
      "notes": "Native Kapampangan noun/adjective expressing comfort, ease, or contentment. 'Kanyaman ya' means 'he/she feels comfortable/at ease'. Related to the adjective 'manyaman' (delicious/pleasant)."
    },
    {
      "id": "adj-karimla",
      "word": "karimla",
      "partOfSpeech": "adjective",
      "translations": ["sour", "tart", "acidic"],
      "relatedTagalog": "maasim",
      "examples": [
        {
          "kp": "Karimla ya ing prutas a ini.",
          "en": "This fruit is sour."
        },
        {
          "kp": "Karimla ya ing danum a ita.",
          "en": "That water is acidic/tart."
        }
      ],
      "notes": "Native Kapampangan taste adjective for sour, tart, or acidic flavors. Equivalent to Tagalog 'maasim'. Attested in the Sunstar Pampanga food vocabulary contexts."
    },
    {
      "id": "adj-mali",
      "word": "mali",
      "partOfSpeech": "adjective",
      "translations": ["wrong", "mistaken", "incorrect"],
      "relatedTagalog": "mali",
      "examples": [
        {
          "kp": "Mali ya ing bilang.",
          "en": "The number/count is wrong."
        },
        {
          "kp": "Mali ya ing ginawa na.",
          "en": "What he/she did was wrong."
        }
      ],
      "notes": "Shared Philippine word meaning wrong, mistaken, or incorrect. Used in Kapampangan the same way as Tagalog 'mali'. Can function as a predicate ('Mali ya' = it is wrong) or noun ('Mali ku' = I was wrong/I made a mistake)."
    },
    {
      "id": "adj-masikan",
      "word": "masikan",
      "partOfSpeech": "adjective",
      "translations": ["strong", "robust", "sturdy", "tough"],
      "relatedTagalog": "malakas",
      "examples": [
        {
          "kp": "Masikan ya ing lalaki.",
          "en": "The man is strong."
        },
        {
          "kp": "Masikan ya ing pader ning bale.",
          "en": "The wall of the house is sturdy."
        }
      ],
      "notes": "Native Kapampangan adjective meaning strong, robust, or sturdy. Attested in the Sunstar Pampanga headline 'Pamagdatilang Masikan at Malusug king Kabilyan Ngeni' (Staying Strong and Healthy). Equivalent to Tagalog 'malakas'."
    },
    {
      "id": "adj-mataba",
      "word": "mataba",
      "partOfSpeech": "adjective",
      "translations": ["fat", "chubby", "plump"],
      "relatedTagalog": "mataba",
      "examples": [
        {
          "kp": "Mataba ya ing asu.",
          "en": "The dog is fat."
        },
        {
          "kp": "Mataba ya ing anak na.",
          "en": "His/her child is chubby."
        }
      ],
      "notes": "Shared Kapampangan-Tagalog word meaning fat, chubby, or plump. Used as a predicate: 'Mataba ya' (he/she/it is fat). Can apply to people and animals."
    },
    {
      "id": "adj-matulid",
      "word": "matulid",
      "partOfSpeech": "adjective",
      "translations": ["straight", "upright", "direct"],
      "relatedTagalog": "tuwid",
      "examples": [
        {
          "kp": "Matulid ya ing dalan.",
          "en": "The road is straight."
        },
        {
          "kp": "Matulid ya ing tukud.",
          "en": "The post is straight."
        }
      ],
      "notes": "Native Kapampangan adjective meaning straight, upright, or direct. Used for roads, posts, lines, and posture. Equivalent to Tagalog 'tuwid'. The word 'tukud' (post/pole) is safe to use as it appears in attested Kapampangan sources."
    }
  ],
