    {
      "id": "food-manyaman",
      "word": "Manyaman",
      "partOfSpeech": "adjective",
      "translations": [
        "delicious",
        "tasty"
      ],
      "relatedTagalog": "masarap",
      "examples": [
        {
          "kp": "Manyaman ing nasi!",
          "en": "The rice is delicious!"
        },
        {
          "kp": "Manyaman ing lutu mu.",
          "en": "Your cooking is delicious."
        }
      ],
      "notes": "Derived from ma- + niaman. Alternate spelling: maniaman. Very commonly used exclamation in Pampanga."
    },
    {
      "id": "food-maranup",
      "word": "Maranup",
      "partOfSpeech": "adjective",
      "translations": [
        "hungry"
      ],
      "relatedTagalog": "gutom",
      "examples": [
        {
          "kp": "Maranup ku.",
          "en": "I am hungry."
        },
        {
          "kp": "Maranup ko pa.",
          "en": "I am still hungry."
        }
      ],
      "notes": "Root: danup (hunger). Attested in the proverb 'Queng maranup alang masias a tinape' (To the hungry, no bread is ever hard)."
    },
    {
      "id": "food-kabsi",
      "word": "Kabsi",
      "partOfSpeech": "adjective",
      "translations": [
        "full",
        "satiated",
        "having eaten one's fill"
      ],
      "relatedTagalog": "busog",
      "examples": [
        {
          "kp": "Kabsi ko na.",
          "en": "I am already full."
        },
        {
          "kp": "Kabsi ko kareng nasi.",
          "en": "I am full from the rice."
        }
      ],
      "notes": "Commonly heard as 'Kabsi ko!' after a satisfying meal."
    },
    {
      "id": "food-lutu",
      "word": "Lutu",
      "partOfSpeech": "verb",
      "translations": [
        "to cook",
        "cooking"
      ],
      "relatedTagalog": "luto",
      "examples": [
        {
          "kp": "Magluto kung asan.",
          "en": "I will cook fish."
        },
        {
          "kp": "Kanyaman na ning lutu mu.",
          "en": "Your cooking is so good."
        }
      ],
      "notes": "Also used as noun (cooking). Active verb form: magluto / maglutu. Malutu = cooked/ripe (also red)."
    },
