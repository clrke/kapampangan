{
  "id": "food",
  "title": "Food & Eating",
  "entries": [
    {
      "id": "food-mangan",
      "word": "Mangan",
      "partOfSpeech": "verb",
      "translations": [
        "to eat"
      ],
      "relatedTagalog": "kain",
      "examples": [
        {
          "kp": "Mangan na tamu.",
          "en": "Let us eat now."
        },
        {
          "kp": "Bisa kung mangan.",
          "en": "I want to eat."
        }
      ],
      "notes": "Root: kan (food). Active form: mamangan (will eat). Past: mengan."
    },
    {
      "id": "food-minum",
      "word": "Minum",
      "partOfSpeech": "verb",
      "translations": [
        "to drink"
      ],
      "relatedTagalog": "inom",
      "examples": [
        {
          "kp": "Bisa ku minum danum.",
          "en": "I want to drink water."
        },
        {
          "kp": "Minum ku kape.",
          "en": "I am drinking coffee."
        }
      ]
    },
    {
      "id": "food-pamangan",
      "word": "Pamangan",
      "partOfSpeech": "noun",
      "translations": [
        "food",
        "meal"
      ],
      "relatedTagalog": "pagkain",
      "examples": [
        {
          "kp": "Manyaman ing pamangan.",
          "en": "The food is delicious."
        },
        {
          "kp": "Atin pamangan keni.",
          "en": "There is food here."
        }
      ],
      "notes": "Derived from mangan (to eat) with pa- prefix."
    },
    {
      "id": "food-nasi",
      "word": "Nasi",
      "partOfSpeech": "noun",
      "translations": [
        "cooked rice"
      ],
      "relatedTagalog": "kanin",
      "examples": [
        {
          "kp": "Ala tang nasi.",
          "en": "We have no rice."
        },
        {
          "kp": "Bisa kung nasi ampo asan.",
          "en": "I want rice and fish."
        }
      ],
      "notes": "Refers specifically to cooked rice, the staple of the Kapampangan table."
    },
    {
      "id": "food-danum",
      "word": "Danum",
      "partOfSpeech": "noun",
      "translations": [
        "water"
      ],
      "relatedTagalog": "tubig",
      "examples": [
        {
          "kp": "Mainit ya ing danum a ini.",
          "en": "This water is hot."
        },
        {
          "kp": "Bisa ku minum danum.",
          "en": "I want to drink water."
        }
      ]
    },
    {
      "id": "food-asan",
      "word": "Asan",
      "partOfSpeech": "noun",
      "translations": [
        "fish",
        "viand (dish eaten with rice)"
      ],
      "relatedTagalog": "isda",
      "examples": [
        {
          "kp": "Mangan ku asan.",
          "en": "I am eating fish."
        },
        {
          "kp": "Nanu ing asan mu?",
          "en": "What is your viand?"
        }
      ],
      "notes": "Asan can refer broadly to any viand/dish eaten with nasi, or specifically to fish."
    },
    {
      "id": "food-manuk",
      "word": "Manuk",
      "partOfSpeech": "noun",
      "translations": [
        "chicken"
      ],
      "relatedTagalog": "manok",
      "examples": [
        {
          "kp": "Manyaman ing manuk.",
          "en": "The chicken is delicious."
        },
        {
          "kp": "Bisa kung manuk a pamangan.",
          "en": "I want chicken as food."
        }
      ]
    },
    {
      "id": "food-karne",
      "word": "Karne",
      "partOfSpeech": "noun",
      "translations": [
        "meat"
      ],
      "relatedTagalog": "karne",
      "examples": [
        {
          "kp": "Ing karne a ini manyaman ya.",
          "en": "This meat is delicious."
        },
        {
          "kp": "E ku mamangan karne.",
          "en": "I do not eat meat."
        }
      ],
      "notes": "Spanish loanword (carne). Commonly used for beef or pork."
    },
