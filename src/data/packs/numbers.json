{
  "id": "numbers",
  "title": "Numbers & Counting",
  "entries": [
    {
      "id": "num-sero",
      "word": "Sero",
      "partOfSpeech": "number",
      "translations": [
        "zero",
        "0"
      ],
      "relatedTagalog": "sero",
      "examples": [
        {
          "kp": "Sero ing bilang da.",
          "en": "Their count is zero."
        },
        {
          "kp": "Sero degrees Celsius ing temperatura.",
          "en": "The temperature is zero degrees Celsius."
        }
      ],
      "notes": "Spanish loanword (< cero), the standard modern term for zero in Kapampangan. The native word 'ala' also covers 'nothing/none' but is polysemous."
    },
    {
      "id": "num-metung",
      "word": "Metung",
      "partOfSpeech": "number",
      "translations": [
        "one",
        "1"
      ],
      "relatedTagalog": "isa",
      "examples": [
        {
          "kp": "Metung a mansanas ing kakanán ku.",
          "en": "I have one apple."
        },
        {
          "kp": "Metung lang anak da.",
          "en": "They have only one child."
        }
      ],
      "notes": "Used when designating one thing. Before a noun: 'Metung a' (linker). Variant spelling 'metong' is in the avoid-list; this entry uses the standard 'Metung'."
    },
    {
      "id": "num-adwa",
      "word": "Adwa",
      "partOfSpeech": "number",
      "translations": [
        "two",
        "2"
      ],
      "relatedTagalog": "dalawa",
      "examples": [
        {
          "kp": "Adwa la reng pusa.",
          "en": "The cats are two. / There are two cats."
        },
        {
          "kp": "Adwang mansanas ing kakanán ku.",
          "en": "I have two apples."
        }
      ],
      "notes": "Also spelled 'adua'. Takes the linker suffix -ng before nouns starting with a consonant (adwang tao) or linker 'a' before vowel-initial nouns."
    },
    {
      "id": "num-atlu",
      "word": "Atlu",
      "partOfSpeech": "number",
      "translations": [
        "three",
        "3"
      ],
      "relatedTagalog": "tatlo",
      "examples": [
        {
          "kp": "Atlu la reng anak.",
          "en": "There are three children."
        },
        {
          "kp": "Atlung aldo na ing byahe.",
          "en": "The trip is three days."
        }
      ],
      "notes": "Takes linker: 'Atlung' before consonant-initial nouns, 'Atlu a' before vowel-initial nouns."
    },
    {
      "id": "num-apat",
      "word": "Apat",
      "partOfSpeech": "number",
      "translations": [
        "four",
        "4"
      ],
      "relatedTagalog": "apat",
      "examples": [
        {
          "kp": "Apat a paa ning aso.",
          "en": "A dog has four legs."
        },
        {
          "kp": "Apat la reng mansanas.",
          "en": "There are four apples."
        }
      ],
      "notes": "Same form in Tagalog and Kapampangan. Linker: 'Apat a' before nouns."
    },
    {
      "id": "num-lima",
      "word": "Lima",
      "partOfSpeech": "number",
      "translations": [
        "five",
        "5"
      ],
      "relatedTagalog": "lima",
      "examples": [
        {
          "kp": "Lima la reng daliri ning kamut.",
          "en": "A hand has five fingers."
        },
        {
          "kp": "Lima a piso ing presyu.",
          "en": "The price is five pesos."
        }
      ],
      "notes": "Same form in Tagalog and Kapampangan. Linker: 'Lima a' or 'Limang' before nouns."
    },
    {
      "id": "num-anam",
      "word": "Anam",
      "partOfSpeech": "number",
      "translations": [
        "six",
        "6"
      ],
      "relatedTagalog": "anim",
      "examples": [
        {
          "kp": "Anam a bulan ing kapiganakan.",
          "en": "The pregnancy is six months."
        },
        {
          "kp": "Anam la reng bibi.",
          "en": "There are six ducks."
        }
      ],
      "notes": "Tagalog cognate is 'anim'. Kapampangan form is 'anam'. Linker: 'Anam a'."
    },
    {
      "id": "num-pitu",
      "word": "Pitu",
      "partOfSpeech": "number",
      "translations": [
        "seven",
        "7"
      ],
      "relatedTagalog": "pito",
      "examples": [
        {
          "kp": "Pitu la reng aldo king sangdominggo.",
          "en": "There are seven days in a week."
        },
        {
          "kp": "Pitu a piso ing nabayad ku.",
          "en": "I paid seven pesos."
        }
      ],
      "notes": "Very close to Tagalog 'pito'. Linker: 'Pitong' before consonants, 'Pitu a' before vowels."
    },
    {
      "id": "num-walu",
      "word": "Walu",
      "partOfSpeech": "number",
      "translations": [
        "eight",
        "8"
      ],
      "relatedTagalog": "walo",
      "examples": [
        {
          "kp": "Walu la reng bibi.",
          "en": "There are eight ducks."
        },
        {
          "kp": "Walu a oras ing tulog.",
          "en": "The sleep is eight hours."
        }
      ],
      "notes": "Also written 'ualu' in older texts. The Spanish-influenced variant 'otchu' exists but 'walu' is the native form."
    },
    {
      "id": "num-siyam",
      "word": "Siyam",
      "partOfSpeech": "number",
      "translations": [
        "nine",
        "9"
      ],
      "relatedTagalog": "siyam",
      "examples": [
        {
          "kp": "Siyam a bulan ing pamagsabyan.",
          "en": "Pregnancy is nine months."
        },
        {
          "kp": "Siyam la reng anak.",
          "en": "There are nine children."
        }
      ],
      "notes": "Same form in Tagalog. Linker: 'Siyam a' before nouns."
    },
    {
      "id": "num-apulu",
      "word": "Apulu",
      "partOfSpeech": "number",
      "translations": [
        "ten",
        "10"
      ],
      "relatedTagalog": "sampu",
      "examples": [
        {
          "kp": "Apulu la reng daliri.",
          "en": "There are ten fingers."
        },
        {
          "kp": "Apulu a piso ing bayad.",
          "en": "The payment is ten pesos."
        }
      ],
      "notes": "Distinct from Tagalog 'sampu'. 'Apulu' is the native Kapampangan word for ten, used as the base for compound numbers (e.g., adwang pulu = twenty)."
    },
    {
      "id": "num-labing-metung",
      "word": "Labing metung",
      "partOfSpeech": "number",
      "translations": [
        "eleven",
        "11"
      ],
      "relatedTagalog": "labing-isa",
      "examples": [
        {
          "kp": "Labing metung la reng estudyante.",
          "en": "There are eleven students."
        },
        {
          "kp": "Labing metung a piso ing sukli.",
          "en": "The change is eleven pesos."
        }
      ],
      "notes": "'Labing' derives from 'apulu' (ten) and serves as the teen prefix for 11–19. 'Labing metung' = ten + one. Spanish loanword 'onsi' also used colloquially."
    },
    {
      "id": "num-adwang-pulu",
      "word": "Adwang pulu",
      "partOfSpeech": "number",
      "translations": [
        "twenty",
        "20"
      ],
      "relatedTagalog": "dalawampu",
      "examples": [
        {
          "kp": "Adwang pulu la reng anak.",
          "en": "There are twenty children."
        },
        {
          "kp": "Adwang pulu a piso ing presyu.",
          "en": "The price is twenty pesos."
        }
      ],
      "notes": "Literally 'two tens'. Also written 'adwampulu'. Spanish loanword 'benti/beynti' is also widely used. Attested in a Sun.Star headline: 'Adwampulu't walung banwa' (28 years)."
    },
    {
      "id": "num-dinalan",
      "word": "Dinalan",
      "partOfSpeech": "number",
      "translations": [
        "one hundred",
        "100"
      ],
      "relatedTagalog": "isang daan",
      "examples": [
        {
          "kp": "Dinalan a piso ing presyu.",
          "en": "The price is one hundred pesos."
        },
        {
          "kp": "Dinalan la reng bisita.",
          "en": "There are one hundred guests."
        }
      ],
      "notes": "Native Kapampangan word for 100. Also expressed as 'metung a dalan'. Spanish loanword 'siyento' is also used. Attested in Bergano's 1732 dictionary."
    },
    {
      "id": "num-libu",
      "word": "Libu",
      "partOfSpeech": "number",
      "translations": [
        "one thousand",
        "1000"
      ],
      "relatedTagalog": "isang libo",
      "examples": [
        {
          "kp": "Libu a piso ing utang ku.",
          "en": "My debt is one thousand pesos."
        },
        {
          "kp": "Libu la reng tao king plasa.",
          "en": "There are one thousand people in the plaza."
        }
      ],
      "notes": "Also expressed as 'metung a libu'. Widely attested across modern and historical Kapampangan sources."
    },
    {
      "id": "num-pilan",
      "word": "Pilan",
      "partOfSpeech": "adverb",
      "translations": [
        "how many?",
        "how much?"
      ],
      "relatedTagalog": "ilan",
      "examples": [
        {
          "kp": "Pilan la reng mansanas?",
          "en": "How many apples are there?"
        },
        {
          "kp": "Pilan na ka banwa?",
          "en": "How many years old are you? / How old are you?"
        }
      ],
      "notes": "WH-question word meaning 'how many'. Corresponds to Tagalog 'ilan'. Frequently used in market and counting contexts. Attested in Mirikitani's Speaking Kapampangan."
    },
    {
      "id": "num-bilang",
      "word": "Bilang",
      "partOfSpeech": "noun",
      "translations": [
        "count",
        "number",
        "numeral"
      ],
      "relatedTagalog": "bilang",
      "examples": [
        {
          "kp": "Nanu ing bilang da?",
          "en": "What is their count?"
        },
        {
          "kp": "Maragul a bilang ning tao ing miboto.",
          "en": "A large number of people voted."
        }
      ],
      "notes": "Functions as both noun ('count, number') and verb root ('to count'). Related forms include: bilangan (to count something), mamilang (to count), gangsal a bilang (odd number). Attested in Bergano's dictionary and forum sources."
    },
    {
      "id": "num-labing",
      "word": "Labing",
      "partOfSpeech": "particle",
      "translations": [
        "teen- (prefix for 11–19)",
        "plus ten"
      ],
      "relatedTagalog": "labing",
      "examples": [
        {
          "kp": "Labing adwa la reng estudyante.",
          "en": "There are twelve students."
        },
        {
          "kp": "Labing lima a piso ing kakanán.",
          "en": "The food costs fifteen pesos."
        }
      ],
      "notes": "Prefix/particle used to form the teen numbers 11–19. 'Labing metung' (11), 'Labing adwa' (12), ... 'Labing siyam' (19). The headword 'Labing' appears as a standalone token in both examples as part of the phrase."
    }
  ],
