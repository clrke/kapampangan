{
  "id": "family",
  "title": "Family & People",
  "entries": [
    {
      "id": "fam-ima",
      "word": "Ima",
      "partOfSpeech": "noun",
      "translations": ["mother"],
      "relatedTagalog": "ina / nanay",
      "examples": [
        {"kp": "Mayap ya ing Ima ku.", "en": "My mother is well."},
        {"kp": "Maragul ya ing Ima ku.", "en": "My mother is great."}
      ],
      "notes": "The common Kapampangan word for mother. Also sometimes 'Indu' in older or more formal usage."
    },
    {
      "id": "fam-tatang",
      "word": "Tatang",
      "partOfSpeech": "noun",
      "translations": ["father"],
      "relatedTagalog": "tatay / ama",
      "examples": [
        {"kp": "Matua ne ing Tatang ku.", "en": "My father is already old."},
        {"kp": "Tatang ku ing mangutang.", "en": "My father is the one who borrows."}
      ],
      "notes": "Common word for father. Alternate form: Ibpa (more formal/archaic)."
    },
    {
      "id": "fam-anak",
      "word": "Anak",
      "partOfSpeech": "noun",
      "translations": ["child", "kid", "son", "daughter"],
      "relatedTagalog": "anak",
      "examples": [
        {"kp": "Ninu ing Anak a yan?", "en": "Who is that child?"},
        {"kp": "Metung yang Anak ing meyari ku.", "en": "I have one child."}
      ],
      "notes": "Shared with Tagalog. Gender-neutral; specify 'anak a lalaki' (son) or 'anak a babai' (daughter) for specificity."
    },
    {
      "id": "fam-kapatad",
      "word": "Kapatad",
      "partOfSpeech": "noun",
      "translations": ["sibling", "brother", "sister"],
      "relatedTagalog": "kapatid",
      "examples": [
        {"kp": "Malagu ing Kapatad ku.", "en": "My sibling is beautiful."},
        {"kp": "Adwa ring Kapatad ku.", "en": "I have two siblings."}
      ],
      "notes": "Gender-neutral term for sibling. Related: Koya (older brother), Achi (older sister), Wali (younger sibling)."
    },
    {
      "id": "fam-koya",
      "word": "Koya",
      "partOfSpeech": "noun",
      "translations": ["older brother"],
      "relatedTagalog": "kuya",
      "examples": [
        {"kp": "Mayap ya ing Koya ku.", "en": "My older brother is good."},
        {"kp": "Koya ku ing makatua.", "en": "My older brother is the eldest."}
      ],
      "notes": "Chinese loanword. Used both as a kinship term and as a respectful address to older males."
    },
    {
      "id": "fam-achi",
      "word": "Achi",
      "partOfSpeech": "noun",
      "translations": ["older sister"],
      "relatedTagalog": "ate",
      "examples": [
        {"kp": "Matulid ya ing Achi ku.", "en": "My older sister is upright."},
        {"kp": "Achi ku ing talaturu.", "en": "My older sister is the one who teaches."}
      ],
      "notes": "Also spelled 'Atsi'. Chinese loanword. Used as kinship term and respectful address."
    },
    {
      "id": "fam-wali",
      "word": "Wali",
      "partOfSpeech": "noun",
      "translations": ["younger sibling"],
      "relatedTagalog": "bunso / kapatid na bunso",
      "examples": [
        {"kp": "Guagua pa ing Wali ku.", "en": "My younger sibling is still little."},
        {"kp": "Tutulungan ku ing Wali ku.", "en": "I will help my younger sibling."}
      ],
      "notes": "Refers specifically to a younger sibling, regardless of gender."
    },
    {
      "id": "fam-ingkung",
      "word": "Ingkung",
      "partOfSpeech": "noun",
      "translations": ["grandfather"],
      "relatedTagalog": "lolo",
      "examples": [
        {"kp": "Matua ne ing Ingkung ku.", "en": "My grandfather is already old."},
        {"kp": "Mayap ya ing Ingkung ku kaku.", "en": "My grandfather is good to me."}
      ],
      "notes": "Chinese loanword. Wikipedia notes this refers to maternal grandfather in some usage, though commonly used for grandfather in general."
    },
    {
      "id": "fam-apu",
      "word": "Apu",
      "partOfSpeech": "noun",
      "translations": ["grandmother", "grandparent"],
      "relatedTagalog": "lola",
      "examples": [
        {"kp": "Maragul ing Apu ku.", "en": "My grandmother is great."},
        {"kp": "Apu ku ing migluto.", "en": "My grandmother is the one who cooked."}
      ],
      "notes": "Chinese loanword. Can also mean 'grandchild' in some contexts, and 'Impu' is used for maternal grandmother specifically. Commonly used for grandmother."
    },
    {
      "id": "fam-bapa",
      "word": "Bapa",
      "partOfSpeech": "noun",
      "translations": ["uncle"],
      "relatedTagalog": "tito / tiyo",
      "examples": [
        {"kp": "Mayap ya ing Bapa ku.", "en": "My uncle is kind."},
        {"kp": "Bapa ku ing makatuang lalaki.", "en": "My uncle is the older man."}
      ],
      "notes": "Informal short form: 'Bap'. Confirmed across multiple Kapampangan sources."
    },
    {
      "id": "fam-dara",
      "word": "Dara",
      "partOfSpeech": "noun",
      "translations": ["aunt"],
      "relatedTagalog": "tita / tiya",
      "examples": [
        {"kp": "Masanting ya ing Dara ku.", "en": "My aunt is beautiful."},
        {"kp": "Dara ku ing tumawag kaku.", "en": "My aunt is the one who called me."}
      ],
      "notes": "Informal short form: 'Dar'. Confirmed in Kapampangan vocabulary sources."
    },
    {
      "id": "fam-pamilia",
      "word": "Pamilia",
      "partOfSpeech": "noun",
      "translations": ["family"],
      "relatedTagalog": "pamilya",
      "examples": [
        {"kp": "Maragul ing Pamilia ku.", "en": "My family is great."},
        {"kp": "Ding Pamilia ku atyu la keni.", "en": "My family is here."}
      ],
      "notes": "Confirmed in multiple Kapampangan vocabulary sources as the standard word for family."
    },
    {
      "id": "fam-kamaganak",
      "word": "Kamaganak",
      "partOfSpeech": "noun",
      "translations": ["relatives", "kinfolk"],
      "relatedTagalog": "kamag-anak",
      "examples": [
        {"kp": "Ding Kamaganak ku mapaglugud la.", "en": "My relatives are loving."},
        {"kp": "Ding Kamaganak tamu pagsarian la.", "en": "Our relatives must be visited personally."}
      ],
      "notes": "The second example is attested in documented Kapampangan text."
    },
    {
      "id": "fam-asawa",
      "word": "Asawa",
      "partOfSpeech": "noun",
      "translations": ["spouse", "husband", "wife"],
      "relatedTagalog": "asawa",
      "examples": [
        {"kp": "Ini ing malagung Asawa ku.", "en": "This is my beautiful spouse."},
        {"kp": "Mayap ya ing Asawa ku.", "en": "My spouse is well."}
      ],
      "notes": "Gender-neutral; refers to husband or wife. Attested by native speakers on Quora and WordReference forums."
    },
    {
      "id": "fam-lalaki",
      "word": "Lalaki",
      "partOfSpeech": "noun",
      "translations": ["man", "male"],
      "relatedTagalog": "lalaki",
      "examples": [
        {"kp": "Dinatang ya ing Lalaki.", "en": "The man arrived."},
        {"kp": "Ninu la reng Lalaki?", "en": "Who are those men?"}
      ],
      "notes": "Attested in grammar examples on multiple sites. Also used as an adjective modifier: 'anak a lalaki' (son)."
    },
    {
      "id": "fam-babai",
      "word": "Babai",
      "partOfSpeech": "noun",
      "translations": ["woman", "female"],
      "relatedTagalog": "babae",
      "examples": [
        {"kp": "Malagu ing Babai.", "en": "The woman is beautiful."},
        {"kp": "Ing Babai ing talaturu king anak.", "en": "The woman is the one teaching the child."}
      ],
      "notes": "Also spelled 'Babayi'. Confirmed as Kapampangan word for woman. Also used as modifier: 'anak a babai' (daughter)."
    },
    {
      "id": "fam-kaluguran",
      "word": "Kaluguran",
      "partOfSpeech": "noun",
      "translations": ["friend", "beloved", "dear one"],
      "relatedTagalog": "kaibigan / minamahal",
      "examples": [
        {"kp": "Mayap yang Kaluguran ing talaturung i Juan.", "en": "The teacher John is a good friend."},
        {"kp": "Kaluguran daka.", "en": "I love you / You are my beloved."}
      ],
      "notes": "Stress-dependent: 'Kaluguran' (stressed first syllable) = friend/pal; 'Kaluguran' (stressed last syllable) = beloved/lover. Wiktionary-verified. From root 'lugud' (love, affection)."
    },
    {
      "id": "fam-lagyu",
      "word": "Lagyu",
      "partOfSpeech": "noun",
      "translations": ["name"],
      "relatedTagalog": "pangalan",
      "examples": [
        {"kp": "Nanu ing Lagyu mu?", "en": "What is your name?"},
        {"kp": "Juan ya ing Lagyu ku.", "en": "My name is Juan."}
      ],
      "notes": "Wiktionary-attested. Also spelled 'laggiu' in older orthographies. The phrase 'Nanu ing lagyu mu?' is one of the most-cited Kapampangan sentences."
    },
    {
      "id": "fam-tau",
      "word": "Tau",
      "partOfSpeech": "noun",
      "translations": ["person", "people"],
      "relatedTagalog": "tao",
      "examples": [
        {"kp": "Mayap yang Tau ing Tatang ku.", "en": "My father is a good person."},
        {"kp": "Ninu ing Tau a yan?", "en": "Who is that person?"}
      ],
      "notes": "Also spelled 'taw'. The phrase 'Tau Kapampangan' is used to describe Kapampangan people as an ethnic group."
    }
  ],
